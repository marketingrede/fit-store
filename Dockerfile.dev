# syntax=docker/dockerfile:1
# Desenvolvimento local: docker compose up --build

ARG RUBY_VERSION=3.4.8
FROM docker.io/library/ruby:${RUBY_VERSION}-slim

WORKDIR /rails

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git curl libsqlite3-dev libyaml-dev pkg-config \
      nodejs npm sqlite3 libvips42 && \
    rm -rf /var/lib/apt/lists/*

ENV BUNDLE_PATH=/usr/local/bundle \
    RAILS_ENV=development \
    BINDING=0.0.0.0

COPY Gemfile ./
RUN bundle lock && bundle install

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

RUN chmod +x bin/* 2>/dev/null || true && \
    sed -i 's/\r$//g' bin/* 2>/dev/null || true

EXPOSE 3000 3036

ENTRYPOINT ["/rails/bin/docker-entrypoint"]
CMD ["/rails/bin/dev"]
