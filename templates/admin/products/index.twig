{% extends 'layouts/admin.twig' %}

{% import 'admin/products/_list_macros.twig' as admin %}

{% block admin_data %}
  <script>
    window.__ADMIN_PRODUCTS__ = {{ products|json_encode|raw }};
    window.__CATEGORIES__ = {{ categories|json_encode|raw }};
    window.__TAGS__ = {{ tags|json_encode|raw }};
    window.__VARIATION_PRESETS__ = {{ variation_presets|json_encode|raw }};
    {% if modal_form %}
    window.__MODAL_FORM__ = {{ modal_form|json_encode|raw }};
    {% endif %}
  </script>
{% endblock %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Produtos</h1>
      <p class="admin-page-subtitle">Gerencie o catálogo da loja.</p>
    </div>
    <button type="button" class="btn-admin" data-action="product-create">
      <i data-lucide="plus"></i> Novo produto
    </button>
  </header>

  {% if flash %}
    <div class="admin-alert {{ flash.type == 'success' ? 'admin-alert--success' : 'admin-alert--error' }}">
      {% if flash.type == 'success' %}<i data-lucide="circle-check"></i>{% else %}<i data-lucide="circle-alert"></i>{% endif %}
      {{ flash.message }}
    </div>
  {% endif %}

  <form
    class="admin-list-toolbar"
    method="get"
    action="/admin/produtos"
    hx-get="/admin/produtos"
    hx-target="#admin-products-list"
    hx-push-url="true"
    hx-swap="outerHTML"
    hx-trigger="submit, change from:select, keyup changed delay:400ms from:#adminProductSearch"
  >
    <input type="hidden" name="sort" value="{{ filters.sort|default('id') }}">
    <input type="hidden" name="dir" value="{{ filters.dir|default('asc') }}">
    <div class="admin-list-toolbar__search">
      <label class="sr-only" for="adminProductSearch">Buscar produto</label>
      <input
        type="search"
        id="adminProductSearch"
        name="q"
        value="{{ filters.q }}"
        placeholder="Buscar por nome..."
        autocomplete="off"
      >
    </div>
    <div class="admin-list-toolbar__filters">
      <label class="sr-only" for="adminProductCategory">Categoria</label>
      <select id="adminProductCategory" name="categoria">
        <option value="">Todas as categorias</option>
        {% for slug, label in categories %}
          <option value="{{ slug }}" {{ filters.categoria == slug ? 'selected' : '' }}>{{ label }}</option>
        {% endfor %}
      </select>
      <label class="sr-only" for="adminProductStatus">Status</label>
      <select id="adminProductStatus" name="status">
        <option value="">Todos os status</option>
        <option value="ativo" {{ filters.status == 'ativo' ? 'selected' : '' }}>Ativo</option>
        <option value="inativo" {{ filters.status == 'inativo' ? 'selected' : '' }}>Inativo</option>
      </select>
      <label class="sr-only" for="adminProductPerPage">Itens por página</label>
      <select id="adminProductPerPage" name="per_page" title="Itens por página">
        {% for size in per_page_options %}
          <option value="{{ size }}" {{ pagination.per_page == size ? 'selected' : '' }}>{{ size }} por página</option>
        {% endfor %}
      </select>
      <button type="submit" class="btn-admin secondary">Filtrar</button>
      {% if filters.q or filters.categoria or filters.status %}
        <a
          href="/admin/produtos"
          class="btn-admin secondary"
          hx-get="/admin/produtos"
          hx-target="#admin-products-list"
          hx-push-url="true"
          hx-swap="outerHTML"
        >Limpar</a>
      {% endif %}
    </div>
  </form>

  {% include 'admin/products/_list_results.twig' %}

  {# Modal — criar / editar #}
  <div class="modal-overlay" id="productFormOverlay" aria-hidden="true">
    <div class="modal modal--wide modal--product-form" role="dialog" aria-modal="true" aria-labelledby="productFormTitle">
      <div class="modal-header">
        <div class="modal-title" id="productFormTitle">Novo produto</div>
        <button type="button" class="modal-close" data-close-modal aria-label="Fechar"><i data-lucide="x"></i></button>
      </div>
      <div class="modal-body modal-body--product-form">
        {% include 'admin/products/_form.twig' with { product: null, categories: categories, filters: filters, pagination: pagination } %}
      </div>
    </div>
    <div
      class="product-image-lightbox"
      id="productImageLightbox"
      hidden
      aria-hidden="true"
      role="dialog"
      aria-modal="true"
      aria-label="Visualização ampliada da imagem"
      data-lightbox-backdrop
    >
      <button type="button" class="product-image-lightbox__close" data-lightbox-close aria-label="Fechar">
        <i data-lucide="x"></i>
      </button>
      <button type="button" class="product-image-lightbox__nav product-image-lightbox__nav--prev" data-lightbox-prev aria-label="Imagem anterior" hidden>
        <i data-lucide="chevron-left"></i>
      </button>
      <figure class="product-image-lightbox__figure">
        <img src="" alt="" data-lightbox-img>
        <figcaption class="product-image-lightbox__caption" data-lightbox-caption></figcaption>
        <span class="product-image-lightbox__counter" data-lightbox-counter></span>
      </figure>
      <button type="button" class="product-image-lightbox__nav product-image-lightbox__nav--next" data-lightbox-next aria-label="Próxima imagem" hidden>
        <i data-lucide="chevron-right"></i>
      </button>
    </div>
  </div>

  {# Modal — visualizar #}
  <div class="modal-overlay" id="productPreviewOverlay" aria-hidden="true">
    <div class="modal modal--preview" role="dialog" aria-modal="true" aria-labelledby="productPreviewTitle">
      <div class="modal-header">
        <div>
          <div class="modal-title" id="productPreviewTitle">Visualizar produto</div>
          <p class="modal-subtitle">Prévia do card no catálogo da loja.</p>
        </div>
        <div class="modal-header-actions">
          <a href="#" id="productPreviewStoreLink" class="btn-admin secondary" target="_blank" rel="noopener">
            Abrir na loja
          </a>
          <button type="button" class="modal-close" data-close-modal aria-label="Fechar"><i data-lucide="x"></i></button>
        </div>
      </div>
      <div class="modal-body modal-body--flush" id="productPreviewBody"></div>
    </div>
  </div>
{% endblock %}
