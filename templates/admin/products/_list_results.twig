{% import 'admin/products/_list_macros.twig' as admin %}

<div id="admin-products-list">
  <p class="admin-list-summary">
  {% if pagination.total == 0 %}
    Nenhum produto encontrado
  {% elseif pagination.total == 1 %}
    1 produto
  {% else %}
    {{ pagination.total }} produtos
  {% endif %}
  {% if filters.q or filters.categoria or filters.status %} com os filtros aplicados{% endif %}
  </p>

  <form
    id="adminProductsBulkForm"
    class="admin-bulk-form"
    method="post"
    action="/admin/produtos/lote"
    data-bulk-form
  >
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
    <input type="hidden" name="_list_q" value="{{ filters.q|default('') }}">
    <input type="hidden" name="_list_categoria" value="{{ filters.categoria|default('') }}">
    <input type="hidden" name="_list_status" value="{{ filters.status|default('') }}">
    <input type="hidden" name="_list_page" value="{{ pagination.page|default(1) }}">
    <input type="hidden" name="_list_sort" value="{{ filters.sort|default('id') }}">
    <input type="hidden" name="_list_dir" value="{{ filters.dir|default('asc') }}">
    <input type="hidden" name="_list_per_page" value="{{ pagination.per_page|default(15) }}">

    <div class="admin-bulk-bar" data-bulk-bar hidden>
      <p class="admin-bulk-bar__count" data-bulk-count>0 selecionados</p>
      <div class="admin-bulk-bar__fields">
        <label class="admin-bulk-bar__field">
          <span>Categoria</span>
          <select name="bulk_category">
            <option value="__keep__">— não alterar —</option>
            {% for slug, label in categories %}
              <option value="{{ slug }}">{{ label }}</option>
            {% endfor %}
          </select>
        </label>
        <label class="admin-bulk-bar__field">
          <span>Tag</span>
          <select name="bulk_tag">
            <option value="__keep__">— não alterar —</option>
            {% for tag in tags|default([]) %}
              <option value="{{ tag.name }}">{{ tag.name }}</option>
            {% endfor %}
          </select>
        </label>
      </div>
      <button type="submit" class="btn-admin" data-bulk-apply>
        <i data-lucide="save"></i> Aplicar em lote
      </button>
      <button type="button" class="btn-admin danger" data-bulk-delete>
        <i data-lucide="trash-2"></i> Excluir selecionados
      </button>
    </div>
  </form>

  <form
    id="adminProductsBulkDeleteForm"
    method="post"
    action="/admin/produtos/lote/excluir"
    data-bulk-delete-form
    hidden
  >
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
    <input type="hidden" name="_list_q" value="{{ filters.q|default('') }}">
    <input type="hidden" name="_list_categoria" value="{{ filters.categoria|default('') }}">
    <input type="hidden" name="_list_status" value="{{ filters.status|default('') }}">
    <input type="hidden" name="_list_page" value="{{ pagination.page|default(1) }}">
    <input type="hidden" name="_list_sort" value="{{ filters.sort|default('id') }}">
    <input type="hidden" name="_list_dir" value="{{ filters.dir|default('asc') }}">
    <input type="hidden" name="_list_per_page" value="{{ pagination.per_page|default(15) }}">
    <div data-bulk-delete-ids></div>
  </form>

  <div class="admin-card admin-card--table" style="margin-top:12px;padding:0;overflow:hidden;" data-bulk-table>
      <table class="admin-table admin-table--sortable admin-table--selectable">
        <thead>
          <tr>
            <th scope="col" class="admin-table__check-col">
              <input type="checkbox" data-bulk-select-all aria-label="Selecionar todos desta página">
            </th>
            <th scope="col">{{ admin.th_sort(filters, 'id', 'ID')|raw }}</th>
            <th scope="col">{{ admin.th_sort(filters, 'name', 'Produto')|raw }}</th>
            <th scope="col">{{ admin.th_sort(filters, 'category', 'Categoria')|raw }}</th>
            <th scope="col">{{ admin.th_sort(filters, 'tag', 'Tag')|raw }}</th>
            <th scope="col">{{ admin.th_sort(filters, 'price_fitc', 'FITC')|raw }}</th>
            <th scope="col">{{ admin.th_sort(filters, 'active', 'Status')|raw }}</th>
            <th scope="col">Ações</th>
          </tr>
        </thead>
        <tbody>
          {% for product in products %}
            <tr>
              <td class="admin-table__check-col">
                <input
                  type="checkbox"
                  name="product_ids[]"
                  value="{{ product.id }}"
                  form="adminProductsBulkForm"
                  data-bulk-row
                  aria-label="Selecionar {{ product.name }}"
                >
              </td>
              <td style="color:var(--text-muted);">{{ product.id }}</td>
              <td style="font-weight:600;">{{ product.name }}</td>
              <td>{{ categories[product.category] ?? product.category }}</td>
              <td>{{ product.tag|default('Geral') }}</td>
              <td>{{ product.price_fitc }}</td>
              <td>
                <span class="status-pill {{ product.active ? 'published' : 'draft' }}">
                  {{ product.active ? 'Ativo' : 'Inativo' }}
                </span>
              </td>
              <td>
                <div class="btn-row">
                  <button type="button" class="btn-admin secondary btn-admin--icon" data-action="product-view" data-id="{{ product.id }}" title="Ver" aria-label="Ver">
                    <i data-lucide="eye"></i>
                  </button>
                  <button type="button" class="btn-admin secondary btn-admin--icon" data-action="product-edit" data-id="{{ product.id }}" title="Editar" aria-label="Editar">
                    <i data-lucide="pencil"></i>
                  </button>
                  <form method="post" action="/admin/produtos/{{ product.id }}/excluir" onsubmit="return confirm('Excluir este produto?');">
                    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                    <button type="submit" class="btn-admin danger btn-admin--icon" title="Excluir" aria-label="Excluir">
                      <i data-lucide="trash-2"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          {% else %}
            <tr>
              <td colspan="8" style="text-align:center;color:var(--text-muted);padding:24px;">
                {% if filters.q or filters.categoria or filters.status %}
                  Nenhum produto encontrado com os filtros atuais.
                {% else %}
                  Nenhum produto cadastrado.
                {% endif %}
              </td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
  </div>

  {% if pagination.total_pages > 1 %}
    <nav class="admin-pagination" aria-label="Paginação de produtos">
      {% if pagination.page > 1 %}
        <a
          class="admin-pagination__btn"
          href="/admin/produtos{{ admin.list_query(filters, pagination.page - 1) }}"
          hx-get="/admin/produtos{{ admin.list_query(filters, pagination.page - 1) }}"
          hx-target="#admin-products-list"
          hx-push-url="true"
          hx-swap="outerHTML"
        >Anterior</a>
      {% else %}
        <span class="admin-pagination__btn is-disabled">Anterior</span>
      {% endif %}

      <span class="admin-pagination__info">
        Página {{ pagination.page }} de {{ pagination.total_pages }}
      </span>

      {% if pagination.page < pagination.total_pages %}
        <a
          class="admin-pagination__btn"
          href="/admin/produtos{{ admin.list_query(filters, pagination.page + 1) }}"
          hx-get="/admin/produtos{{ admin.list_query(filters, pagination.page + 1) }}"
          hx-target="#admin-products-list"
          hx-push-url="true"
          hx-swap="outerHTML"
        >Próxima</a>
      {% else %}
        <span class="admin-pagination__btn is-disabled">Próxima</span>
      {% endif %}
    </nav>
  {% elseif pagination.total > 0 %}
    <p class="admin-pagination__info admin-pagination__info--solo">
      Exibindo {{ products|length }} de {{ pagination.total }} produtos
    </p>
  {% endif %}

  <script type="application/json" id="admin-products-data">{{ products|json_encode|raw }}</script>
</div>
