{% macro list_query(filters, page) %}
  {%- set parts = [] -%}
  {%- if filters.q %}{% set parts = parts|merge(['q=' ~ filters.q|url_encode]) %}{% endif -%}
  {%- if filters.categoria %}{% set parts = parts|merge(['categoria=' ~ filters.categoria|url_encode]) %}{% endif -%}
  {%- if filters.status %}{% set parts = parts|merge(['status=' ~ filters.status|url_encode]) %}{% endif -%}
  {%- if filters.sort|default('id') != 'id' %}{% set parts = parts|merge(['sort=' ~ filters.sort|url_encode]) %}{% endif -%}
  {%- if filters.dir|default('asc') == 'desc' %}{% set parts = parts|merge(['dir=desc']) %}{% endif -%}
  {%- if filters.per_page|default(15) != 15 %}{% set parts = parts|merge(['per_page=' ~ filters.per_page]) %}{% endif -%}
  {%- if page and page > 1 %}{% set parts = parts|merge(['page=' ~ page]) %}{% endif -%}
  {{ parts ? '?' ~ parts|join('&') : '' }}
{% endmacro %}

{% macro sort_url(filters, column) %}
  {%- set is_active = filters.sort|default('id') == column -%}
  {%- set next_dir = is_active and filters.dir|default('asc') == 'asc' ? 'desc' : 'asc' -%}
  {%- set next_filters = filters|merge({ sort: column, dir: next_dir }) -%}
  {{ _self.list_query(next_filters, 1) }}
{% endmacro %}

{% macro th_sort(filters, column, label) %}
  {%- set is_active = filters.sort|default('id') == column -%}
  {%- set dir = filters.dir|default('asc') -%}
  {%- set href = '/admin/produtos' ~ _self.sort_url(filters, column) -%}
  <a
    href="{{ href }}"
    class="admin-th-sort{{ is_active ? ' is-active is-' ~ dir : '' }}"
    hx-get="{{ href }}"
    hx-target="#admin-products-list"
    hx-push-url="true"
    hx-swap="outerHTML"
    aria-sort="{{ is_active ? (dir == 'asc' ? 'ascending' : 'descending') : 'none' }}"
  >
    <span>{{ label }}</span>
    {% if is_active %}
      <i data-lucide="{{ dir == 'asc' ? 'arrow-up' : 'arrow-down' }}" aria-hidden="true"></i>
    {% else %}
      <i data-lucide="arrow-up-down" aria-hidden="true"></i>
    {% endif %}
  </a>
{% endmacro %}
