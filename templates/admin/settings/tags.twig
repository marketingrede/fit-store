{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <nav class="admin-breadcrumb" aria-label="Navegação">
        <a href="/admin/configuracoes">Configurações</a>
        <i data-lucide="chevron-right" aria-hidden="true"></i>
        <span>Tags</span>
      </nav>
      <h1 class="admin-page-title">Tags (badges)</h1>
      <p class="admin-page-subtitle">Etiquetas exibidas nos cards e no modal de produto.</p>
    </div>
    <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
      <i data-lucide="store"></i> Ver loja
    </a>
  </header>

  <div id="settings-flash">
    {% if flash %}
      {% include 'admin/settings/partials/_flash_alert.twig' %}
    {% endif %}
  </div>

  <div class="admin-settings-layout">
    <aside class="admin-settings-form-card admin-card">
      <header class="admin-settings-form-card__head">
        <h2 class="admin-settings-form-card__title"><i data-lucide="circle-plus"></i> Nova tag</h2>
        <p class="admin-settings-form-card__hint">A prévia atualiza enquanto você digita.</p>
      </header>
      <form
        method="post"
        action="/admin/configuracoes/tags"
        class="admin-settings-form"
        data-new-tag-form
        hx-post="/admin/configuracoes/tags"
        hx-target="#tags-tbody"
        hx-swap="innerHTML"
        hx-on::after-request="if(event.detail.successful) this.reset()"
      >
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <div class="admin-settings-form-preview">
          <span class="admin-tag-preview" data-new-tag-preview style="--tag-color: #0f766e">Nova tag</span>
        </div>
        <fieldset class="admin-settings-fieldset">
          <div class="field">
            <label for="tagName">Nome</label>
            <input type="text" id="tagName" name="name" required placeholder="Ex: Proteína" data-tag-name-input>
          </div>
          <div class="field">
            <label>Cor do badge</label>
            {% include 'admin/partials/_color_picker.twig' with { name: 'color', value: '#0f766e', id: 'newTagColor' } %}
          </div>
        </fieldset>
        <fieldset class="admin-settings-fieldset">
          <legend>Exibição</legend>
          <div class="admin-settings-form-row">
            <div class="field">
              <label for="tagSort">Ordem</label>
              <input type="number" id="tagSort" name="sort_order" value="0" min="0">
            </div>
            <label class="admin-toggle" title="Tag ativa">
              <input type="checkbox" name="active" value="1" checked>
              <span class="admin-toggle__track" aria-hidden="true"></span>
              <span class="admin-toggle__label">Ativa</span>
            </label>
          </div>
        </fieldset>
        <button type="submit" class="btn-admin admin-settings-form__submit"><i data-lucide="plus"></i> Adicionar</button>
      </form>
    </aside>

    <section class="admin-settings-list-card admin-card">
      <header class="admin-settings-list-card__head">
        <h2 class="admin-settings-list-card__title"><i data-lucide="tag"></i> Tags cadastradas</h2>
        <p class="admin-settings-list-card__hint">Preview ao vivo da cor e do nome.</p>
      </header>
      <div class="admin-table-wrap admin-settings-table-wrap">
        <table class="admin-table admin-settings-table">
          <thead>
            <tr>
              <th class="admin-settings-th--preview">Preview</th>
              <th>Nome</th>
              <th>Cor</th>
              <th class="admin-settings-th--narrow">Ordem</th>
              <th class="admin-settings-th--center">Ativa</th>
              <th class="admin-settings-th--actions">Ações</th>
              <th class="admin-settings-th--actions"></th>
            </tr>
          </thead>
          <tbody id="tags-tbody">
            {% include 'admin/settings/partials/_tags_rows.twig' %}
          </tbody>
        </table>
      </div>
    </section>
  </div>
{% endblock %}
