{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <nav class="admin-breadcrumb" aria-label="Navegação">
        <a href="/admin/configuracoes">Configurações</a>
        <i data-lucide="chevron-right" aria-hidden="true"></i>
        <span>Categorias</span>
      </nav>
      <h1 class="admin-page-title">Categorias</h1>
      <p class="admin-page-subtitle">Defina as categorias usadas nos filtros da loja.</p>
    </div>
    <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
      <i data-lucide="store"></i> Ver loja
    </a>
  </header>

  <div id="settings-flash">
    {% if flash %}
      {% include 'admin/settings/partials/_flash_alert.twig' %}
    {% endif %}
  </div>

  <div class="admin-settings-layout">
    <aside class="admin-settings-form-card admin-card">
      <header class="admin-settings-form-card__head">
        <h2 class="admin-settings-form-card__title"><i data-lucide="circle-plus"></i> Nova categoria</h2>
        <p class="admin-settings-form-card__hint">Aparece nos filtros do catálogo.</p>
      </header>
      <form
        method="post"
        action="/admin/configuracoes/categorias"
        class="admin-settings-form"
        data-category-form
        hx-post="/admin/configuracoes/categorias"
        hx-target="#categories-tbody"
        hx-swap="innerHTML"
        hx-on::after-request="if(event.detail.successful) this.reset()"
      >
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <fieldset class="admin-settings-fieldset">
          <div class="field">
            <label for="catLabel">Nome exibido</label>
            <input type="text" id="catLabel" name="label" required placeholder="Ex: Proteínas" data-cat-label autocomplete="off">
          </div>
          <div class="field">
            <label for="catSlug">Slug (URL)</label>
            <input type="text" id="catSlug" name="slug" placeholder="proteinas" data-cat-slug autocomplete="off" spellcheck="false" inputmode="url">
            <p class="admin-field-hint">Gerado automaticamente a partir do nome. Edite só se precisar de um slug específico.</p>
          </div>
        </fieldset>
        <fieldset class="admin-settings-fieldset">
          <legend>Exibição</legend>
          <div class="admin-settings-form-row">
            <div class="field">
              <label for="catSort">Ordem</label>
              <input type="number" id="catSort" name="sort_order" value="0" min="0">
            </div>
            <label class="admin-toggle" title="Categoria ativa">
              <input type="checkbox" name="active" value="1" checked>
              <span class="admin-toggle__track" aria-hidden="true"></span>
              <span class="admin-toggle__label">Ativa</span>
            </label>
          </div>
        </fieldset>
        <button type="submit" class="btn-admin admin-settings-form__submit"><i data-lucide="plus"></i> Adicionar</button>
      </form>
    </aside>

    <section class="admin-settings-list-card admin-card">
      <header class="admin-settings-list-card__head">
        <h2 class="admin-settings-list-card__title"><i data-lucide="folders"></i> Categorias cadastradas</h2>
        <p class="admin-settings-list-card__hint">Edite inline e salve linha a linha.</p>
      </header>
      <div class="admin-table-wrap admin-settings-table-wrap">
        <table class="admin-table admin-settings-table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Slug</th>
              <th class="admin-settings-th--narrow">Ordem</th>
              <th class="admin-settings-th--center">Ativa</th>
              <th class="admin-settings-th--actions">Ações</th>
              <th class="admin-settings-th--actions"></th>
            </tr>
          </thead>
          <tbody id="categories-tbody">
            {% include 'admin/settings/partials/_categories_rows.twig' %}
          </tbody>
        </table>
      </div>
    </section>
  </div>
{% endblock %}
