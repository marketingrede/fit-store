{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <nav class="admin-breadcrumb" aria-label="Navegação">
        <a href="/admin/configuracoes">Configurações</a>
        <i data-lucide="chevron-right" aria-hidden="true"></i>
        <span>Variações</span>
      </nav>
      <h1 class="admin-page-title">Presets de variação</h1>
      <p class="admin-page-subtitle">Modelos reutilizáveis ao cadastrar produtos (tamanho, volume, cor…).</p>
    </div>
    <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
      <i data-lucide="store"></i> Ver loja
    </a>
  </header>

  <div id="settings-flash">
    {% if flash %}
      {% include 'admin/settings/partials/_flash_alert.twig' %}
    {% endif %}
  </div>

  <div class="admin-variations-page admin-settings-layout">
    <aside class="admin-settings-form-card admin-card">
      <header class="admin-settings-form-card__head">
        <h2 class="admin-settings-form-card__title"><i data-lucide="circle-plus"></i> Novo preset</h2>
        <p class="admin-settings-form-card__hint">Uma opção por linha ou separadas por vírgula.</p>
      </header>
      <form
        method="post"
        action="/admin/configuracoes/variacoes"
        class="admin-settings-form admin-variation-preset-form"
        data-new-variation-form
        hx-post="/admin/configuracoes/variacoes"
        hx-target="#variations-list"
        hx-swap="innerHTML"
        hx-on::after-request="if(event.detail.successful) { this.reset(); this.dispatchEvent(new CustomEvent('variation-form:reset')); }"
      >
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <fieldset class="admin-settings-fieldset">
          <div class="admin-variation-preset-fields">
            <div class="field">
              <label for="presetName">Nome do atributo</label>
              <input type="text" id="presetName" name="name" required placeholder="Ex: Tamanho" autocomplete="off">
            </div>
            <div class="field admin-variation-preset-fields__unit">
              <label for="presetUnit">Unidade (opcional)</label>
              <input type="text" id="presetUnit" name="unit" placeholder="ml, g…" autocomplete="off">
            </div>
          </div>
          <div class="field admin-variation-preset-fields__options">
            <label for="presetOptions">Opções</label>
            <textarea id="presetOptions" name="options" rows="4" required placeholder="P&#10;M&#10;G&#10;GG" data-options-input></textarea>
            <div class="admin-option-chips" data-option-chips aria-hidden="true"></div>
          </div>
        </fieldset>
        <fieldset class="admin-settings-fieldset">
          <legend>Comportamento</legend>
          <div class="admin-settings-flags admin-variation-preset-flags">
            <label class="admin-flag-toggle">
              <input type="checkbox" name="required" value="1" checked>
              <span>Obrigatório</span>
            </label>
            <label class="admin-flag-toggle">
              <input type="checkbox" name="allow_option_image" value="1">
              <span>Imagem por opção</span>
            </label>
          </div>
          <div class="admin-settings-form-row">
            <div class="field">
              <label for="presetSort">Ordem</label>
              <input type="number" id="presetSort" name="sort_order" value="0" min="0">
            </div>
            <label class="admin-toggle" title="Preset ativo">
              <input type="checkbox" name="active" value="1" checked>
              <span class="admin-toggle__track" aria-hidden="true"></span>
              <span class="admin-toggle__label">Ativo</span>
            </label>
          </div>
        </fieldset>
        <button type="submit" class="btn-admin admin-settings-form__submit"><i data-lucide="plus"></i> Adicionar</button>
      </form>
    </aside>

    <section class="admin-settings-list-card admin-card">
      <header class="admin-settings-list-card__head admin-variation-list__head">
        <div>
          <h2 class="admin-settings-list-card__title"><i data-lucide="sliders-horizontal"></i> Presets cadastrados</h2>
          <p class="admin-settings-list-card__hint">Edite cada preset no próprio card e clique em Salvar.</p>
        </div>
        <div class="admin-variation-list__actions">
          <button type="button" class="btn-admin secondary" data-variation-expand-all>
            <i data-lucide="chevrons-down"></i> Expandir todos
          </button>
          <button type="button" class="btn-admin secondary" data-variation-collapse-all>
            <i data-lucide="chevrons-up"></i> Recolher todos
          </button>
        </div>
      </header>
      <div id="variations-list" class="admin-variation-list" data-variations-list>
        {% include 'admin/settings/partials/_variations_rows.twig' %}
      </div>
    </section>
  </div>
{% endblock %}
