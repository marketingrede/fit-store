{% set classes = 'catalog-feature-card catalog-feature-card--desktop catalog-feature-card--' ~ item.variant|default('teal') ~ (item.image_url ? ' catalog-feature-card--has-image' : '') %}

<article class="{{ classes }}" data-cta-preview-card aria-hidden="true">
  {% if item.image_url %}
    <img
      src="{{ item.image_url }}"
      alt=""
      class="catalog-feature-card__image"
      data-cta-preview-image
    >
  {% else %}
    <img src="" alt="" class="catalog-feature-card__image" data-cta-preview-image hidden>
  {% endif %}

  <div class="catalog-feature-card__content" data-cta-preview-content {{ not (item.title or item.body or item.link_label) ? 'hidden' : '' }}>
    <h2 class="catalog-feature-card__title" data-cta-preview-title>{{ item.title }}</h2>
    <p class="catalog-feature-card__text" data-cta-preview-body>{{ item.body }}</p>
    <span class="catalog-feature-card__cta" data-cta-preview-link-label>{{ item.link_label }}</span>
  </div>
</article>
