{% for item in items %}
  <tr class="admin-settings-row" data-settings-row data-tag-row>
    <form
      method="post"
      action="/admin/configuracoes/tags/{{ item.id }}"
      class="admin-row-form"
      hx-post="/admin/configuracoes/tags/{{ item.id }}"
      hx-target="#tags-tbody"
      hx-swap="innerHTML"
    >
      <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
      <td class="admin-settings-cell--preview" data-label="Preview">
        <span class="admin-tag-preview" data-tag-preview style="--tag-color: {{ item.color|default('#6b7280') }}">{{ item.name }}</span>
      </td>
      <td data-label="Nome">
        <input
          type="text"
          name="name"
          value="{{ item.name }}"
          required
          class="admin-input-inline"
          data-tag-name-input
          aria-label="Nome da tag"
        >
      </td>
      <td data-label="Cor">
        {% include 'admin/partials/_color_picker.twig' with { name: 'color', value: item.color|default('#6b7280'), id: 'tagColor' ~ item.id, compact: true } %}
      </td>
      <td class="admin-settings-cell--narrow" data-label="Ordem">
        <input type="number" name="sort_order" value="{{ item.sort_order }}" min="0" class="admin-input-inline admin-input-inline--narrow" aria-label="Ordem">
      </td>
      <td class="admin-settings-cell--center" data-label="Status">
        <label class="admin-toggle admin-toggle--table" title="Tag ativa">
          <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
          <span class="admin-toggle__track" aria-hidden="true"></span>
          <span class="sr-only">Ativa</span>
        </label>
      </td>
      <td class="admin-settings-cell--actions">
        <div class="admin-settings-row-actions">
          <button type="submit" class="btn-admin secondary btn-admin--icon" title="Salvar" aria-label="Salvar">
            <i data-lucide="save"></i>
          </button>
        </div>
      </td>
    </form>
    <td class="admin-settings-cell--actions">
      <form
        method="post"
        action="/admin/configuracoes/tags/{{ item.id }}/excluir"
        hx-post="/admin/configuracoes/tags/{{ item.id }}/excluir"
        hx-target="#tags-tbody"
        hx-swap="innerHTML"
        hx-confirm="Excluir esta tag?"
      >
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <button type="submit" class="btn-admin danger btn-admin--icon" title="Excluir" aria-label="Excluir">
          <i data-lucide="trash-2"></i>
        </button>
      </form>
    </td>
  </tr>
{% else %}
  <tr>
    <td colspan="7" class="admin-table__empty">Nenhuma tag cadastrada.</td>
  </tr>
{% endfor %}
