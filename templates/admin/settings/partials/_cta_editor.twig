{% set slot = item.slot %}
{% set slotHint = slot == 1 ? 'Primeiro elemento da primeira linha do grid' : 'Último elemento da segunda linha do grid' %}

<section class="admin-cta-editor admin-card" data-cta-editor data-slot="{{ slot }}">
  <div class="admin-cta-editor__preview-col">
    <div class="admin-cta-editor__preview-head">
      <div>
        <span class="admin-cta-editor__badge">Card {{ slot }}</span>
        <p class="admin-cta-editor__hint">{{ slotHint }}</p>
        <span class="admin-cta-editor__status" data-cta-save-status hidden aria-live="polite"></span>
      </div>
      <label class="admin-toggle" title="Exibir na loja">
        <input type="hidden" name="cards[{{ slot }}][active]" value="0">
        <input
          type="checkbox"
          name="cards[{{ slot }}][active]"
          value="1"
          data-cta-active
          {{ (item.active|default(0)) == 1 ? 'checked' : '' }}
        >
        <span class="admin-toggle__track" aria-hidden="true"></span>
        <span class="admin-toggle__label">Ativo</span>
      </label>
    </div>

    <div class="admin-cta-editor__preview-frame" data-cta-preview>
      {% include 'admin/settings/partials/_cta_preview.twig' with { item: item } %}
      <div class="admin-cta-editor__inactive-veil{{ (item.active|default(0)) == 1 ? '' : ' is-visible' }}" data-cta-inactive-veil>
        <span>Inativo na loja</span>
      </div>
    </div>
  </div>

  <div class="admin-cta-editor__form-col">
    <fieldset class="admin-cta-fieldset">
      <legend>Cor de fundo</legend>
      <div class="admin-cta-variants" role="radiogroup" aria-label="Cor do card">
        {% for value, label in { teal: 'Verde', blue: 'Azul', surface: 'Claro' } %}
          <label class="admin-cta-variant {{ item.variant == value ? 'is-selected' : '' }}" data-cta-variant-option>
            <input
              type="radio"
              name="cards[{{ slot }}][variant]"
              value="{{ value }}"
              data-cta-variant
              {{ item.variant == value ? 'checked' : '' }}
            >
            <span class="admin-cta-variant__swatch admin-cta-variant__swatch--{{ value }}" aria-hidden="true"></span>
            <span class="admin-cta-variant__label">{{ label }}</span>
          </label>
        {% endfor %}
      </div>
    </fieldset>

    <fieldset class="admin-cta-fieldset">
      <legend>Conteúdo</legend>
      <div class="admin-cta-fields">
        <div class="field">
          <label for="ctaTitle{{ slot }}">Título</label>
          <input
            type="text"
            id="ctaTitle{{ slot }}"
            name="cards[{{ slot }}][title]"
            value="{{ item.title }}"
            data-cta-title
            placeholder="Ex: Bebida proteica"
            maxlength="120"
          >
        </div>
        <div class="field">
          <label for="ctaBody{{ slot }}">Texto</label>
          <textarea
            id="ctaBody{{ slot }}"
            name="cards[{{ slot }}][body]"
            rows="2"
            data-cta-body
            placeholder="Breve descrição do destaque"
            maxlength="280"
          >{{ item.body }}</textarea>
        </div>
      </div>
    </fieldset>

    <fieldset class="admin-cta-fieldset">
      <legend>Link</legend>
      <div class="admin-cta-fields admin-cta-fields--pair">
        <div class="field">
          <label for="ctaLink{{ slot }}">URL</label>
          <input
            type="text"
            id="ctaLink{{ slot }}"
            name="cards[{{ slot }}][link_url]"
            value="{{ item.link_url }}"
            placeholder="https://... ou /rota"
          >
        </div>
        <div class="field">
          <label for="ctaLabel{{ slot }}">Texto do botão</label>
          <input
            type="text"
            id="ctaLabel{{ slot }}"
            name="cards[{{ slot }}][link_label]"
            value="{{ item.link_label }}"
            data-cta-link-label
            placeholder="Ex: Saiba mais"
            maxlength="60"
          >
        </div>
      </div>
    </fieldset>

    <fieldset class="admin-cta-fieldset">
      <legend>Imagem</legend>
      <input type="hidden" name="cards[{{ slot }}][image_url]" value="{{ item.image_url }}" data-cta-image-url>

      <label class="admin-cta-upload" data-cta-upload>
        <input
          type="file"
          id="ctaImageFile{{ slot }}"
          name="cards[{{ slot }}][image_file]"
          accept="image/png,image/jpeg,image/webp"
          data-cta-image-file
          class="admin-cta-upload__input"
        >
        <span class="admin-cta-upload__icon" aria-hidden="true"><i data-lucide="image-plus"></i></span>
        <span class="admin-cta-upload__text">
          <strong>Enviar imagem</strong>
          <span>PNG, JPG ou WebP</span>
        </span>
      </label>

      {% if item.image_url %}
        <div class="admin-cta-image-actions">
          <label class="admin-cta-remove-image">
            <input type="checkbox" name="cards[{{ slot }}][remove_image]" value="1" data-cta-remove-image>
            <i data-lucide="trash-2"></i>
            Remover imagem atual
          </label>
        </div>
      {% endif %}
    </fieldset>
  </div>
</section>
