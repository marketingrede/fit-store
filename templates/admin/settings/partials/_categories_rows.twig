{% for item in items %}
  <tr class="admin-settings-row" data-settings-row>
    <form
      method="post"
      action="/admin/configuracoes/categorias/{{ item.id }}"
      class="admin-row-form"
      hx-post="/admin/configuracoes/categorias/{{ item.id }}"
      hx-target="#categories-tbody"
      hx-swap="innerHTML"
    >
      <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
      <td data-label="Nome">
        <input type="text" name="label" value="{{ item.label }}" required class="admin-input-inline" aria-label="Nome">
      </td>
      <td data-label="Slug">
        <input type="text" name="slug" value="{{ item.slug }}" required class="admin-input-inline admin-input-inline--mono" aria-label="Slug">
      </td>
      <td class="admin-settings-cell--narrow" data-label="Ordem">
        <input type="number" name="sort_order" value="{{ item.sort_order }}" min="0" class="admin-input-inline admin-input-inline--narrow" aria-label="Ordem">
      </td>
      <td class="admin-settings-cell--center" data-label="Status">
        <label class="admin-toggle admin-toggle--table" title="Categoria ativa">
          <input type="checkbox" name="active" value="1" {{ item.active ? 'checked' : '' }}>
          <span class="admin-toggle__track" aria-hidden="true"></span>
          <span class="sr-only">Ativa</span>
        </label>
      </td>
      <td class="admin-settings-cell--actions">
        <div class="admin-settings-row-actions">
          <button type="submit" class="btn-admin secondary btn-admin--icon" title="Salvar" aria-label="Salvar">
            <i data-lucide="save"></i>
          </button>
        </div>
      </td>
    </form>
    <td class="admin-settings-cell--actions">
      <form
        method="post"
        action="/admin/configuracoes/categorias/{{ item.id }}/excluir"
        hx-post="/admin/configuracoes/categorias/{{ item.id }}/excluir"
        hx-target="#categories-tbody"
        hx-swap="innerHTML"
        hx-confirm="Excluir esta categoria?"
      >
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <button type="submit" class="btn-admin danger btn-admin--icon" title="Excluir" aria-label="Excluir">
          <i data-lucide="trash-2"></i>
        </button>
      </form>
    </td>
  </tr>
{% else %}
  <tr>
    <td colspan="6" class="admin-table__empty">Nenhuma categoria cadastrada.</td>
  </tr>
{% endfor %}
