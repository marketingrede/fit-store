{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <nav class="admin-breadcrumb" aria-label="Navegação">
        <a href="/admin/configuracoes">Configurações</a>
        <i data-lucide="chevron-right" aria-hidden="true"></i>
        <span>Cards CTA</span>
      </nav>
      <h1 class="admin-page-title">Cards CTA do catálogo</h1>
      <p class="admin-page-subtitle">Dois destaques exibidos no grid desktop da loja. A prévia atualiza em tempo real; o toggle Ativo salva imediatamente na loja.</p>
    </div>
    <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
      <i data-lucide="store"></i> Ver loja
    </a>
  </header>

  <div id="settings-flash">
    {% if flash %}
      {% include 'admin/settings/partials/_flash_alert.twig' %}
    {% endif %}
  </div>

  <form
    method="post"
    action="/admin/configuracoes/ctas"
    enctype="multipart/form-data"
    class="admin-cta-form"
    data-cta-form
  >
    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="admin-cta-grid">
      {% for item in items %}
        {% include 'admin/settings/partials/_cta_editor.twig' with { item: item } %}
      {% endfor %}
    </div>

    <div class="admin-form-actions admin-form-actions--sticky">
      <button type="submit" class="btn-admin"><i data-lucide="save"></i> Salvar cards CTA</button>
    </div>
  </form>
{% endblock %}
