{% extends 'layouts/admin.twig' %}

{% block title %}Colaboradores | Admin {{ app_name }}{% endblock %}

{% block admin_content %}
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-header__title">Colaboradores</h1>
      <p class="admin-page-header__subtitle">Gestão de colaboradores, saldos e resgates Fitcoin</p>
    </div>
  </div>

  <div class="admin-stats-grid">
    <div class="admin-stat-card admin-stat-card--link" onclick="location.href='/admin/colaboradores/elegiveis'">
      <div class="admin-stat-card__icon admin-stat-card__icon--teal"><i data-lucide="users"></i></div>
      <div class="admin-stat-card__body">
        <div class="admin-stat-card__label">Elegíveis</div>
        <div class="admin-stat-card__value">{{ stats.total_eligible }}</div>
        <div class="admin-stat-card__hint">{{ stats.active_eligible }} ativos</div>
      </div>
    </div>
    <div class="admin-stat-card admin-stat-card--link" onclick="location.href='/admin/colaboradores/contas'">
      <div class="admin-stat-card__icon admin-stat-card__icon--blue"><i data-lucide="user-check"></i></div>
      <div class="admin-stat-card__body">
        <div class="admin-stat-card__label">Cadastrados</div>
        <div class="admin-stat-card__value">{{ stats.registered }}</div>
        <div class="admin-stat-card__hint">de {{ stats.total_eligible }} elegíveis</div>
      </div>
    </div>
    <div class="admin-stat-card admin-stat-card--link" onclick="location.href='/admin/colaboradores/saldos'">
      <div class="admin-stat-card__icon admin-stat-card__icon--teal"><i data-lucide="wallet"></i></div>
      <div class="admin-stat-card__body">
        <div class="admin-stat-card__label">Total FITC</div>
        <div class="admin-stat-card__value">{{ stats.total_balance }}</div>
        <div class="admin-stat-card__hint">em circulação</div>
      </div>
    </div>
    <div class="admin-stat-card admin-stat-card--link" onclick="location.href='/admin/colaboradores/pedidos'">
      <div class="admin-stat-card__icon admin-stat-card__icon--blue"><i data-lucide="shopping-bag"></i></div>
      <div class="admin-stat-card__body">
        <div class="admin-stat-card__label">Resgates</div>
        <div class="admin-stat-card__value">{{ stats.total_orders }}</div>
        <div class="admin-stat-card__hint">pedidos realizados</div>
      </div>
    </div>
  </div>

  <div class="admin-actions-grid" style="margin-top:20px">
    <a href="/admin/colaboradores/elegiveis" class="admin-action-card">
      <div class="admin-action-card__icon"><i data-lucide="list-plus"></i></div>
      <div class="admin-action-card__body">
        <div class="admin-action-card__title">Elegíveis</div>
        <div class="admin-action-card__desc">Importar e gerenciar whitelist</div>
      </div>
    </a>
    <a href="/admin/colaboradores/contas" class="admin-action-card">
      <div class="admin-action-card__icon"><i data-lucide="users"></i></div>
      <div class="admin-action-card__body">
        <div class="admin-action-card__title">Contas</div>
        <div class="admin-action-card__desc">Colaboradores cadastrados</div>
      </div>
    </a>
    <a href="/admin/colaboradores/saldos" class="admin-action-card">
      <div class="admin-action-card__icon"><i data-lucide="coins"></i></div>
      <div class="admin-action-card__body">
        <div class="admin-action-card__title">Saldos</div>
        <div class="admin-action-card__desc">Crédito e débito manual</div>
      </div>
    </a>
    <a href="/admin/colaboradores/pedidos" class="admin-action-card">
      <div class="admin-action-card__icon"><i data-lucide="package"></i></div>
      <div class="admin-action-card__body">
        <div class="admin-action-card__title">Pedidos</div>
        <div class="admin-action-card__desc">Acompanhar resgates</div>
      </div>
    </a>
  </div>
{% endblock %}