{% extends 'layouts/admin.twig' %}

{% block title %}Pedidos de Resgate | Admin {{ app_name }}{% endblock %}

{% block admin_content %}
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-header__title">Pedidos de Resgate</h1>
      <p class="admin-page-header__subtitle">Resgates realizados pelos colaboradores</p>
    </div>
    <div class="admin-page-header__actions">
      <a href="/admin/colaboradores" class="btn-admin secondary"><i data-lucide="arrow-left"></i> Voltar</a>
    </div>
  </div>

  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Data</th>
          <th>Colaborador</th>
          <th>Produto</th>
          <th style="text-align:right">FITC</th>
          <th>Status</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        {% for order in orders %}
          <tr>
            <td><strong>{{ order.id }}</strong></td>
            <td class="admin-table__nowrap">{{ order.created_at }}</td>
            <td>
              <a href="/admin/colaboradores/contas/{{ order.employee_id }}" class="admin-table__link">{{ employee_names[order.employee_id] ?? 'Desconhecido' }}</a>
            </td>
            <td>{{ order.product_name }}</td>
            <td style="text-align:right;font-weight:650;color:#b91c1c">-{{ order.product_price_fitc }}</td>
            <td>
              {% if order.status == 'confirmed' %}
                <span class="admin-badge admin-badge--success">Confirmado</span>
              {% elseif order.status == 'fulfilled' %}
                <span class="admin-badge admin-badge--info">Entregue</span>
              {% elseif order.status == 'cancelled' %}
                <span class="admin-badge admin-badge--danger">Cancelado</span>
              {% else %}
                <span class="admin-badge">{{ order.status }}</span>
              {% endif %}
            </td>
            <td>
              <form method="post" action="/admin/colaboradores/pedidos/{{ order.id }}/status" style="display:inline">
                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                <select name="status" onchange="this.form.submit()" style="padding:6px 10px;border:1px solid var(--admin-border);border-radius:var(--radius-md);background:#fff;font:inherit;font-size:.78rem;font-weight:600">
                  <option value="confirmed" {{ order.status == 'confirmed' ? 'selected' : '' }}>Confirmado</option>
                  <option value="fulfilled" {{ order.status == 'fulfilled' ? 'selected' : '' }}>Entregue</option>
                  <option value="cancelled" {{ order.status == 'cancelled' ? 'selected' : '' }}>Cancelado</option>
                </select>
              </form>
            </td>
          </tr>
        {% else %}
          <tr><td colspan="7" class="admin-table__empty">Nenhum pedido registrado.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}