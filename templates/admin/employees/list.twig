{% extends 'layouts/admin.twig' %}

{% block title %}Contas de Colaboradores | Admin {{ app_name }}{% endblock %}

{% block admin_content %}
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-header__title">Contas de Colaboradores</h1>
      <p class="admin-page-header__subtitle">Colaboradores que já criaram conta na plataforma</p>
    </div>
    <div class="admin-page-header__actions">
      <a href="/admin/colaboradores" class="btn-admin secondary"><i data-lucide="arrow-left"></i> Voltar</a>
    </div>
  </div>

  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Matrícula</th>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Saldo</th>
          <th>Último login</th>
          <th>Criado em</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        {% for emp in employees %}
          <tr>
            <td><strong>{{ emp.employee_id }}</strong></td>
            <td>{{ emp.full_name }}</td>
            <td class="admin-table__muted">{{ emp.email }}</td>
            <td><strong style="color:var(--brand-teal-dark)">{{ wallets[emp.id] ?? 0 }}</strong> <span class="admin-table__muted">FITC</span></td>
            <td class="admin-table__muted">{{ emp.last_login_at ?? 'Nunca' }}</td>
            <td class="admin-table__muted">{{ emp.created_at }}</td>
            <td class="admin-table__nowrap">
              <a href="/admin/colaboradores/contas/{{ emp.id }}" class="btn-admin secondary" style="padding:6px 10px;font-size:.78rem">
                <i data-lucide="eye" style="width:13px;height:13px"></i> Detalhes
              </a>
              <form method="post" action="/admin/colaboradores/contas/{{ emp.id }}/excluir" style="display:inline" onsubmit="return confirm('Excluir esta conta do colaborador?')">
                <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                <button type="submit" class="btn-admin danger" style="padding:6px 10px;font-size:.78rem">
                  <i data-lucide="trash-2" style="width:13px;height:13px"></i>
                </button>
              </form>
            </td>
          </tr>
        {% else %}
          <tr><td colspan="7" class="admin-table__empty">Nenhuma conta de colaborador cadastrada.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% endblock %}