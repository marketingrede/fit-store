{% extends 'layouts/admin.twig' %}

{% block title %}Saldos Fitcoin | Admin {{ app_name }}{% endblock %}

{% block admin_content %}
  <div class="admin-page-header">
    <div>
      <h1 class="admin-page-header__title">Saldos Fitcoin</h1>
      <p class="admin-page-header__subtitle">Gerenciar saldos dos colaboradores</p>
    </div>
    <div class="admin-page-header__actions">
      <a href="/admin/colaboradores" class="btn-admin secondary"><i data-lucide="arrow-left"></i> Voltar</a>
    </div>
  </div>

  <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Matrícula</th>
          <th>Nome</th>
          <th style="text-align:right">Saldo</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody>
        {% for emp in employees %}
          <tr>
            <td><strong>{{ emp.employee_id }}</strong></td>
            <td>{{ emp.full_name }}</td>
            <td style="text-align:right">
              <span style="font-size:1.1rem;font-weight:700;color:var(--brand-teal-dark)">{{ wallets[emp.id] ?? 0 }}</span>
              <span class="admin-table__muted">FITC</span>
            </td>
            <td>
              <button type="button" class="btn-admin" style="padding:6px 12px;font-size:.78rem" onclick="openAdjustModal({{ emp.id }}, '{{ emp.full_name|e('js') }}', {{ wallets[emp.id] ?? 0 }})">
                <i data-lucide="pencil" style="width:13px;height:13px"></i> Ajustar saldo
              </button>
            </td>
          </tr>
        {% else %}
          <tr><td colspan="4" class="admin-table__empty">Nenhum colaborador cadastrado.</td></tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div id="adjustModal" style="display:none;position:fixed;inset:0;background:color-mix(in srgb, var(--brand-grey-dark) 28%, transparent);z-index:100;align-items:center;justify-content:center;backdrop-filter:blur(4px)">
    <div style="background:#fff;border-radius:var(--admin-radius);padding:24px;max-width:420px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.15)">
      <h2 style="font-size:1rem;font-weight:700;color:var(--admin-text);margin-bottom:4px">Ajustar Saldo</h2>
      <p style="font-size:.8125rem;color:var(--admin-muted);margin-bottom:16px">
        <strong id="adjustName" style="color:var(--admin-text)"></strong> · Saldo atual: <strong id="adjustCurrent" style="color:var(--brand-teal-dark)"></strong> FITC
      </p>
      <form method="post" action="/admin/colaboradores/saldos/ajustar" id="adjustForm">
        <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
        <input type="hidden" name="employee_id" id="adjustEmployeeId">
        <div style="display:flex;flex-direction:column;gap:12px">
          <div style="display:flex;flex-direction:column;gap:4px">
            <label for="adjustType" style="font-size:.78rem;font-weight:600;color:var(--admin-text)">Tipo de operação</label>
            <select id="adjustType" name="type" style="padding:10px 12px;border:1px solid var(--admin-border);border-radius:var(--radius-md);background:#fff;font:inherit;font-size:.86rem">
              <option value="credit">Crédito (adicionar FITC)</option>
              <option value="debit">Débito (remover FITC)</option>
            </select>
          </div>
          <div style="display:flex;flex-direction:column;gap:4px">
            <label for="adjustAmount" style="font-size:.78rem;font-weight:600;color:var(--admin-text)">Valor (FITC)</label>
            <input type="number" id="adjustAmount" name="amount" min="1" required value="100" style="padding:10px 12px;border:1px solid var(--admin-border);border-radius:var(--radius-md);background:#fff;font:inherit;font-size:.86rem">
          </div>
          <div style="display:flex;flex-direction:column;gap:4px">
            <label for="adjustDescription" style="font-size:.78rem;font-weight:600;color:var(--admin-text)">Descrição</label>
            <input type="text" id="adjustDescription" name="description" placeholder="Ex: Crédito bônus" style="padding:10px 12px;border:1px solid var(--admin-border);border-radius:var(--radius-md);background:#fff;font:inherit;font-size:.86rem">
          </div>
        </div>
        <div style="display:flex;gap:10px;margin-top:20px">
          <button type="submit" class="btn-admin"><i data-lucide="check"></i> Confirmar</button>
          <button type="button" class="btn-admin secondary" onclick="closeAdjustModal()">Cancelar</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openAdjustModal(id, name, balance) {
      document.getElementById('adjustEmployeeId').value = id;
      document.getElementById('adjustName').textContent = name;
      document.getElementById('adjustCurrent').textContent = balance;
      document.getElementById('adjustModal').style.display = 'flex';
    }
    function closeAdjustModal() {
      document.getElementById('adjustModal').style.display = 'none';
    }
    document.getElementById('adjustModal').addEventListener('click', function(e) {
      if (e.target === this) closeAdjustModal();
    });
  </script>
{% endblock %}