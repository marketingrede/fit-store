{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Solicitações de troca</h1>
      <p class="admin-page-subtitle">Pedidos enviados pelos colaboradores via loja.</p>
    </div>
  </header>

  <div class="admin-card admin-card--flush">
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Produto</th>
            <th>Variações</th>
            <th>FITC</th>
          </tr>
        </thead>
        <tbody>
          {% for trade in trades %}
            <tr>
              <td class="admin-table__muted admin-table__nowrap">{{ trade.created_at }}</td>
              <td>{{ trade.name }}</td>
              <td><a href="mailto:{{ trade.email }}" class="admin-table__link">{{ trade.email }}</a></td>
              <td>{{ trade.product_name }}</td>
              <td class="admin-table__muted admin-table__clamp">
                {% if trade.variation_summary %}
                  {{ trade.variation_summary }}
                {% else %}
                  —
                {% endif %}
              </td>
              <td>{{ trade.product_price_fitc }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="6" class="admin-table__empty">Nenhuma solicitação registrada ainda.</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
{% endblock %}
