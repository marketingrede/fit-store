{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Dashboard</h1>
      <p class="admin-page-subtitle">Visão geral da {{ app_name }} — métricas e tendências dos últimos 30 dias.</p>
    </div>
    <div class="admin-page-header__actions">
      <a href="/admin/relatorios" class="btn-admin secondary">
        <i data-lucide="file-down"></i> Relatórios
      </a>
      <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
        <i data-lucide="store"></i> Ver loja
      </a>
    </div>
  </header>

  <div class="admin-stat-grid admin-stat-grid--4">
    <a href="/admin/produtos" class="admin-stat-card admin-stat-card--link">
      <span class="admin-stat-card__icon admin-stat-card__icon--teal"><i data-lucide="package"></i></span>
      <div>
        <p class="admin-stat-card__label">Produtos ativos</p>
        <p class="admin-stat-card__value">{{ stats.product_active }}</p>
        <p class="admin-stat-card__hint">{{ stats.product_inactive }} inativos · {{ stats.product_total }} total</p>
      </div>
    </a>
    <a href="/admin/trocas" class="admin-stat-card admin-stat-card--link">
      <span class="admin-stat-card__icon admin-stat-card__icon--blue"><i data-lucide="arrow-left-right"></i></span>
      <div>
        <p class="admin-stat-card__label">Trocas (30 dias)</p>
        <p class="admin-stat-card__value">{{ stats.trades_30d }}</p>
        <p class="admin-stat-card__hint">{{ stats.trades_7d }} nos últimos 7 dias · {{ stats.trade_total }} total</p>
      </div>
    </a>
    <div class="admin-stat-card">
      <span class="admin-stat-card__icon admin-stat-card__icon--teal"><i data-lucide="coins"></i></span>
      <div>
        <p class="admin-stat-card__label">FITC resgatados</p>
        <p class="admin-stat-card__value">{{ stats.fitc_total|number_format(0, ',', '.') }}</p>
        <p class="admin-stat-card__hint">Média {{ stats.fitc_avg|number_format(1, ',', '.') }} por troca</p>
      </div>
    </div>
    <a href="/admin/anuncios" class="admin-stat-card admin-stat-card--link">
      <span class="admin-stat-card__icon admin-stat-card__icon--blue"><i data-lucide="megaphone"></i></span>
      <div>
        <p class="admin-stat-card__label">Anúncios</p>
        <p class="admin-stat-card__value">{{ stats.announcements_published }}</p>
        <p class="admin-stat-card__hint">{{ stats.announcements_draft }} rascunhos</p>
      </div>
    </a>
  </div>

  <div
    class="admin-dashboard-charts"
    data-dashboard-charts="{{ chart_data|json_encode|e('html_attr') }}"
  >
    <div class="admin-chart-grid">
      <section class="admin-card admin-chart-card admin-chart-card--wide">
        <header class="admin-chart-card__head">
          <h2 class="admin-chart-card__title"><i data-lucide="trending-up"></i> Trocas por dia</h2>
          <span class="admin-chart-card__meta">Últimos 30 dias</span>
        </header>
        <div class="admin-chart-card__body">
          <canvas data-chart="trades_timeline" role="img" aria-label="Gráfico de trocas por dia"></canvas>
        </div>
      </section>

      <section class="admin-card admin-chart-card">
        <header class="admin-chart-card__head">
          <h2 class="admin-chart-card__title"><i data-lucide="trophy"></i> Top produtos</h2>
          <span class="admin-chart-card__meta">Por solicitações</span>
        </header>
        <div class="admin-chart-card__body">
          <canvas data-chart="top_products" role="img" aria-label="Gráfico dos produtos mais trocados"></canvas>
        </div>
      </section>

      <section class="admin-card admin-chart-card">
        <header class="admin-chart-card__head">
          <h2 class="admin-chart-card__title"><i data-lucide="pie-chart"></i> Por categoria</h2>
          <span class="admin-chart-card__meta">Produtos no catálogo</span>
        </header>
        <div class="admin-chart-card__body admin-chart-card__body--compact">
          <canvas data-chart="products_by_category" role="img" aria-label="Gráfico de produtos por categoria"></canvas>
        </div>
      </section>

      <section class="admin-card admin-chart-card">
        <header class="admin-chart-card__head">
          <h2 class="admin-chart-card__title"><i data-lucide="layers"></i> Status do catálogo</h2>
        </header>
        <div class="admin-chart-card__body admin-chart-card__body--compact">
          <canvas data-chart="products_by_status" role="img" aria-label="Gráfico de produtos ativos e inativos"></canvas>
        </div>
      </section>
    </div>
  </div>

  <div class="admin-dashboard-secondary">
    <section class="admin-card admin-mini-stats">
      <h2 class="admin-card__title"><i data-lucide="settings-2"></i> Catálogo</h2>
      <ul class="admin-mini-stats__list">
        <li><span>Categorias ativas</span><strong>{{ stats.categories_active }}</strong></li>
        <li><span>Tags ativas</span><strong>{{ stats.tags_active }}</strong></li>
        <li><span>Produtos com imagem</span><strong>{{ stats.products_with_image }}</strong></li>
      </ul>
      <a href="/admin/configuracoes" class="btn-admin secondary admin-mini-stats__link">
        <i data-lucide="arrow-right"></i> Configurações
      </a>
    </section>

    {% if recentTrades|length > 0 %}
      <section class="admin-section admin-dashboard-trades">
        <h2 class="admin-card__title"><i data-lucide="history"></i> Últimas solicitações</h2>
        <div class="admin-card admin-card--flush">
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Data</th>
                  <th>Nome</th>
                  <th>Produto</th>
                  <th>FITC</th>
                </tr>
              </thead>
              <tbody>
                {% for trade in recentTrades %}
                  <tr>
                    <td class="admin-table__muted">{{ trade.created_at|slice(0, 16) }}</td>
                    <td>{{ trade.name }}</td>
                    <td>{{ trade.product_name }}</td>
                    <td>{{ trade.product_price_fitc }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
        <p class="admin-section__footer">
          <a href="/admin/trocas" class="btn-admin secondary"><i data-lucide="arrow-right"></i> Ver todas</a>
        </p>
      </section>
    {% endif %}
  </div>
{% endblock %}
