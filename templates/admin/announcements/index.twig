{% extends 'layouts/admin.twig' %}

{% block admin_content %}
  <header class="admin-page-header">
    <div>
      <h1 class="admin-page-title">Anúncios</h1>
      <p class="admin-page-subtitle">Gerencie os anúncios exibidos na loja.</p>
    </div>
    <a href="/admin/anuncios/novo" class="btn-admin">
      <i data-lucide="plus"></i> Novo anúncio
    </a>
  </header>

  {% if flash %}
    <div class="admin-alert {{ flash.type == 'success' ? 'admin-alert--success' : 'admin-alert--error' }}">
      {{ flash.message }}
    </div>
  {% endif %}

  {% if announcements|length == 0 %}
    <div class="admin-card admin-card--empty">
      Nenhum anúncio cadastrado ainda.
    </div>
  {% else %}
    <div class="admin-card admin-card--flush">
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Título</th>
              <th>Status</th>
              <th>Publicado em</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {% for ad in announcements %}
              <tr>
                <td><strong>{{ ad.title }}</strong></td>
                <td>
                  <span class="status-pill {{ ad.status }}">{{ ad.status == 'published' ? 'Publicado' : 'Rascunho' }}</span>
                </td>
                <td class="admin-table__muted">{{ ad.published_at ?? '—' }}</td>
                <td>
                  <div class="btn-row">
                    <a href="/admin/anuncios/{{ ad.id }}/editar" class="btn-admin secondary">Editar</a>
                    <form method="post" action="/admin/anuncios/{{ ad.id }}/excluir" onsubmit="return confirm('Excluir este anúncio?');">
                      <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
                      <button type="submit" class="btn-admin danger">Excluir</button>
                    </form>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}
{% endblock %}
