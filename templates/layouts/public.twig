{% extends 'layouts/app.twig' %}

{% block title %}{{ document_title|default(app_name ~ ' — A Loja do Movimenta+') }}{% endblock %}

{% block body %}
  <header class="topbar" data-site-header>
    <div class="topbar-row topbar-row--primary">
      <div class="topbar-brand">
        <a href="/" class="topbar-title"
          hx-get="/" hx-target="#spa-outlet" hx-push-url="true" hx-swap="innerHTML">
          <span class="brand-eyebrow">Movimenta+</span>
          <span class="brand-name">{{ app_name }}</span>
        </a>
      </div>

      <div class="topbar-row__end">
        <form
          class="header-search header-search--desktop"
          id="headerSearchForm"
          role="search"
          action="/"
          method="get"
          hx-get="/"
          hx-target="#spa-outlet"
          hx-push-url="true"
          hx-swap="innerHTML"
          hx-trigger="submit"
        >
          <span data-search-category-fields>
            {% for slug in activeCategories|default([]) %}
              <input type="hidden" name="categorias" value="{{ slug }}">
            {% endfor %}
          </span>
          <span data-search-tag-fields>
            {% for tag in activeTags|default([]) %}
              <input type="hidden" name="tags" value="{{ tag }}">
            {% endfor %}
          </span>
          <span class="header-search__icon" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>
          </span>
          <input type="search" id="headerSearchInput" name="q" value="{{ header_search|default('') }}" placeholder="Buscar..." autocomplete="off" aria-label="Buscar produto">
          <kbd class="header-search__kbd" id="headerSearchKbd" aria-hidden="true"><span class="header-search__kbd-mod" data-search-kbd-mod>Ctrl</span> K</kbd>
          <button type="button" class="header-search__clear" id="headerSearchClear" aria-label="Limpar busca" hidden>&times;</button>
        </form>

        <button type="button" class="filter-toggle" id="filterToggle" aria-expanded="false" aria-controls="filterSheet">
          <span>Filtros</span>
          {% set activeFilterCount = activeCategories|default([])|length + activeTags|default([])|length %}
          <span class="filter-toggle__count" id="filterToggleCount" {{ activeFilterCount == 0 ? 'hidden' : '' }}>{{ activeFilterCount }}</span>
        </button>

        <div class="fitcoin-badge">
          <span class="fitcoin-badge__dot" aria-hidden="true"></span>
          {% block fitcoin_badge %}<span>Preços em</span> <strong>FITC</strong>{% endblock %}
        </div>

        {% if app.session.employee_id is defined and app.session.employee_id %}
          <a href="/colaborador" class="topbar-login topbar-login--employee" title="Área do colaborador">
            <span class="topbar-login__avatar">{{ app.session.employee_name|first|upper }}</span>
            <span class="topbar-login__text">Minha conta</span>
          </a>
        {% else %}
          <a href="/colaborador/login" class="topbar-login" title="Login do colaborador">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span class="topbar-login__text">Entrar</span>
          </a>
        {% endif %}
      </div>
    </div>

    <div class="topbar-row topbar-row--search-mobile">
      <form
        class="header-search header-search--mobile"
        id="headerSearchFormMobile"
        role="search"
        action="/"
        method="get"
        hx-get="/"
        hx-target="#spa-outlet"
        hx-push-url="true"
        hx-swap="innerHTML"
        hx-trigger="submit"
      >
        <span data-search-category-fields>
          {% for slug in activeCategories|default([]) %}
            <input type="hidden" name="categorias" value="{{ slug }}">
          {% endfor %}
        </span>
        <span data-search-tag-fields>
          {% for tag in activeTags|default([]) %}
            <input type="hidden" name="tags" value="{{ tag }}">
          {% endfor %}
        </span>
        <span class="header-search__icon" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3-3"/></svg>
        </span>
        <input type="search" name="q" data-mobile-search-input value="{{ header_search|default('') }}" placeholder="Buscar..." autocomplete="off" aria-label="Buscar produto">
      </form>
    </div>
  </header>

  <div id="spa-outlet">
    {% block main %}{% endblock %}
  </div>

  <footer class="footer">
    <p>{{ app_name }} • A Loja do Movimenta + • Preços fictícios em Fitcoin (FITC)</p>
  </footer>

  {# Bottom sheet de filtros #}
  <div class="filter-sheet-backdrop" id="filterSheetBackdrop" hidden></div>
  <div class="filter-sheet" id="filterSheet" role="dialog" aria-modal="true" aria-labelledby="filterSheetTitle" hidden>
    <div class="filter-sheet__handle" aria-hidden="true"></div>
    <div class="filter-sheet__header">
      <h2 id="filterSheetTitle">Filtrar categorias</h2>
      <button type="button" class="filter-sheet__close" id="filterSheetClose" aria-label="Fechar">&times;</button>
    </div>
    <form
      id="filterSheetForm"
      class="filter-sheet__body"
      action="/"
      method="get"
      hx-get="/"
      hx-target="#spa-outlet"
      hx-push-url="true"
      hx-swap="innerHTML"
      hx-on::after-request="if(event.detail.successful) { window.closeFilterSheet?.(); }"
    >
      {% if header_search|default('') %}
        <input type="hidden" name="q" value="{{ header_search }}">
      {% endif %}
      {% for tag in activeTags|default([]) %}
        <input type="hidden" name="tags" value="{{ tag }}">
      {% endfor %}
      <div data-filter-sheet-grid>
        {% for slug, label in categories %}
          <label
            class="filter-sheet-chip {{ slug in activeCategories|default([]) ? 'active' : '' }}"
            data-filter-sheet-chip
            data-category="{{ slug }}"
          >
            <input type="checkbox" name="categorias" value="{{ slug }}" {{ slug in activeCategories|default([]) ? 'checked' : '' }} hidden>
            {{ label }}
          </label>
        {% endfor %}
      </div>
    </form>
    <div class="filter-sheet__footer">
      <button type="button" class="btn-sheet secondary" id="filterSheetClear">Limpar</button>
      <button type="button" class="btn-sheet primary" id="filterSheetApply">Aplicar</button>
    </div>
  </div>

  {# Modal de anúncios #}
  <div class="modal-overlay" id="announcementOverlay" aria-hidden="true">
    <div class="modal modal--announcement" role="dialog" aria-modal="true" aria-labelledby="announcementModalTitle">
      <div class="modal-header">
        <div class="modal-title" id="announcementModalTitle">Anúncios</div>
        <button type="button" class="modal-close" id="announcementCloseBtn" aria-label="Fechar">Fechar</button>
      </div>
      <div class="modal-body modal-body--flush" id="announcementModalBody"></div>
    </div>
  </div>

  {# Modal de produto #}
  <div class="modal-overlay modal-overlay--product" id="productModalDialog" aria-labelledby="productModalActiveTitle" aria-hidden="true">
    <div class="product-modal-backdrop" tabindex="-1" aria-hidden="true"></div>

    <div class="product-modal-stage" role="document">
      <button type="button" class="product-modal__nav product-modal__nav--prev" id="productModalPrev" aria-label="Produto anterior">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
      </button>

      <div class="modal modal--product">
        <button type="button" class="product-modal__close" id="productModalClose" aria-label="Fechar">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
        </button>
        <p class="product-modal__swipe-hint" id="productModalSwipeHint" aria-hidden="true">Deslize para trocar</p>
        <div class="product-modal-swiper swiper" id="productModalSwiper">
          <div class="swiper-wrapper" id="productModalWrapper"></div>
        </div>
      </div>

      <button type="button" class="product-modal__nav product-modal__nav--next" id="productModalNext" aria-label="Próximo produto">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  {# Modal troca Fitcoin (global) #}
  <div class="order-review-host" id="orderReview" aria-live="polite"></div>
  <div class="modal-overlay" id="tradeOverlay" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="tradeTitle">
      <div class="modal-header">
        <div class="modal-title" id="tradeTitle">Quero trocar meus Fitcoin</div>
        <button type="button" class="modal-close" id="tradeCloseBtn">Fechar</button>
      </div>
      <div class="modal-body">
        <p class="modal-subtitle" id="tradeSubtitle">Preencha seus dados e enviaremos sua solicitação com o produto selecionado.</p>
        <form id="tradeForm">
          <div class="form-grid">
            <div class="field">
              <label for="tradeName">Nome</label>
              <input id="tradeName" name="name" type="text" autocomplete="name" required>
            </div>
            <div class="field">
              <label for="tradeEmail">E-mail</label>
              <input id="tradeEmail" name="email" type="email" autocomplete="email" required>
            </div>
          </div>
          <div class="form-actions">
            <div class="status-text" id="tradeStatus" aria-live="polite"></div>
            <button class="submit-btn" id="tradeSubmitBtn" type="submit">Visualizar pedido</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script type="application/json" id="category-labels">{{ categories|json_encode|raw }}</script>
{% endblock %}
