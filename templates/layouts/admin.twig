{% extends 'layouts/app.twig' %}

{% block styles %}
  {% set adminCss = vite_css('admin') %}
  {% if adminCss %}<link rel="stylesheet" href="{{ adminCss }}">{% endif %}
{% endblock %}

{% block vite_script %}{% endblock %}

{% block body_attrs %} class="admin-body"{% endblock %}

{% block body %}
  <div class="admin-shell" data-admin-shell>
    <div class="admin-sidebar-backdrop" data-sidebar-backdrop hidden></div>

    <aside class="admin-sidebar" id="adminSidebar" aria-label="Menu administrativo">
      <div class="admin-sidebar__brand">
        <a href="/admin" class="admin-sidebar__brand-link" aria-label="Ir para o dashboard">
          <img src="/assets/logo.svg" alt="Movimenta+" class="admin-sidebar__logo" width="461" height="181" decoding="async">
        </a>
        <div class="admin-sidebar__brand-text">
          <strong>{{ app_name }}</strong>
          <span>Painel admin</span>
        </div>
      </div>

      <nav class="admin-sidebar__nav" data-admin-nav>
        <a href="/admin" class="admin-sidebar__link {{ active_nav == 'dashboard' ? 'is-active' : '' }}">
          <i data-lucide="layout-dashboard"></i>
          <span>Dashboard</span>
        </a>
        <a href="/admin/produtos" class="admin-sidebar__link {{ active_nav == 'products' ? 'is-active' : '' }}">
          <i data-lucide="package"></i>
          <span>Produtos</span>
        </a>
        <a href="/admin/anuncios" class="admin-sidebar__link {{ active_nav == 'announcements' ? 'is-active' : '' }}">
          <i data-lucide="megaphone"></i>
          <span>Anúncios</span>
        </a>
        <a href="/admin/trocas" class="admin-sidebar__link {{ active_nav == 'trades' ? 'is-active' : '' }}">
          <i data-lucide="arrow-left-right"></i>
          <span>Trocas</span>
        </a>
        <a href="/admin/relatorios" class="admin-sidebar__link {{ active_nav == 'reports' ? 'is-active' : '' }}">
          <i data-lucide="file-bar-chart"></i>
          <span>Relatórios</span>
        </a>

        <div class="admin-sidebar__section">Catálogo</div>
        <a href="/admin/configuracoes" class="admin-sidebar__link {{ active_nav == 'settings' ? 'is-active' : '' }}">
          <i data-lucide="settings"></i>
          <span>Configurações</span>
        </a>
        <a href="/admin/configuracoes/categorias" class="admin-sidebar__link admin-sidebar__link--sub {{ active_nav == 'settings_categories' ? 'is-active' : '' }}">
          <i data-lucide="folders"></i>
          <span>Categorias</span>
        </a>
        <a href="/admin/configuracoes/tags" class="admin-sidebar__link admin-sidebar__link--sub {{ active_nav == 'settings_tags' ? 'is-active' : '' }}">
          <i data-lucide="tag"></i>
          <span>Tags</span>
        </a>
        <a href="/admin/configuracoes/variacoes" class="admin-sidebar__link admin-sidebar__link--sub {{ active_nav == 'settings_variations' ? 'is-active' : '' }}">
          <i data-lucide="sliders-horizontal"></i>
          <span>Variações</span>
        </a>
        <a href="/admin/configuracoes/ctas" class="admin-sidebar__link admin-sidebar__link--sub {{ active_nav == 'settings_ctas' ? 'is-active' : '' }}">
          <i data-lucide="panel-top"></i>
          <span>Cards CTA</span>
        </a>

        <div class="admin-sidebar__section">Conta</div>
        <a href="/admin/conta" class="admin-sidebar__link {{ active_nav == 'account' ? 'is-active' : '' }}">
          <i data-lucide="user-cog"></i>
          <span>Minha conta</span>
        </a>
        <a href="/" class="admin-sidebar__link admin-sidebar__link--store" target="_blank" rel="noopener">
          <i data-lucide="store"></i>
          <span>Ver loja</span>
        </a>
      </nav>

      <div class="admin-sidebar__footer">
        <form method="post" action="/admin/logout">
          <input type="hidden" name="_csrf" value="{{ csrf_token() }}">
          <button type="submit" class="admin-sidebar__logout">
            <i data-lucide="log-out"></i>
            <span>Sair</span>
          </button>
        </form>
      </div>
    </aside>

    <div class="admin-main">
      <header class="admin-topbar">
        <div>
          <p class="admin-topbar__eyebrow">Movimenta+</p>
          <p class="admin-topbar__title">Painel da {{ app_name }}</p>
        </div>
        <div class="admin-topbar__actions">
          <a href="/" class="btn-admin secondary" target="_blank" rel="noopener">
            <i data-lucide="store"></i> Ver loja
          </a>
        </div>
      </header>

      <header class="admin-topbar-mobile">
        <button type="button" class="admin-topbar-mobile__toggle" data-sidebar-toggle aria-label="Abrir menu">
          <i data-lucide="menu"></i>
        </button>
        <div class="admin-topbar-mobile__brand">
          <img src="/assets/logo.svg" alt="" aria-hidden="true" decoding="async">
          <strong>{{ app_name }}</strong>
        </div>
        <a href="/" class="admin-topbar-mobile__store" target="_blank" rel="noopener" aria-label="Ver loja">
          <i data-lucide="store"></i>
        </a>
      </header>

      <main class="admin-content">
        {% block admin_content %}{% endblock %}
      </main>
    </div>
  </div>
  {% block admin_data %}{% endblock %}
{% endblock %}

{% block scripts %}
  <script type="module" src="{{ vite('admin') }}" defer></script>
  {% block admin_scripts %}{% endblock %}
{% endblock %}
