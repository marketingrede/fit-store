<main class="product-detail-wrapper" data-page="product">
  <a href="/" class="back-link" data-spa-link data-back-catalog>← Voltar para o catálogo</a>

  <section>
    <article class="product-detail-card">
      <div class="product-detail-image">
        <img src="{{ product.image_url }}" alt="{{ product.name }}">
      </div>
      <div>
        <h1 class="product-detail-title">{{ product.name }}</h1>
        <p class="product-detail-category">
          Categoria: {{ categoryLabel }} • Tag: {{ product.tag }}
        </p>
        <p class="product-detail-description">{{ product.description }}</p>
        <p class="product-detail-price">{{ product.price_fitc }} FITC</p>
        <p class="product-detail-meta">
          Use seu saldo de Fitcoin para resgatar este produto.
          Entre em contato com o RH para confirmar disponibilidade.
        </p>
        <div class="cta-row">
          <button class="cta-btn" id="openTradeBtn" type="button">Quero trocar meus Fitcoin</button>
          <span class="cta-helper">Você receberá contato por e-mail.</span>
        </div>
      </div>
    </article>
  </section>

  <section id="orderReview" aria-live="polite"></section>
</main>

<div class="modal-overlay" id="tradeOverlay" aria-hidden="true">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="tradeTitle">
    <div class="modal-header">
      <div class="modal-title" id="tradeTitle">Quero trocar meus Fitcoin</div>
      <button class="modal-close" id="tradeCloseBtn" type="button">Fechar</button>
    </div>
    <div class="modal-body">
      <p class="modal-subtitle" id="tradeSubtitle">
        Preencha seus dados e enviaremos sua solicitação com o produto selecionado.
      </p>
      <form id="tradeForm">
        <div class="form-grid">
          <div class="field">
            <label for="tradeName">Nome</label>
            <input id="tradeName" name="name" type="text" autocomplete="name" required>
          </div>
          <div class="field">
            <label for="tradeEmail">E-mail</label>
            <input id="tradeEmail" name="email" type="email" autocomplete="email" required>
          </div>
        </div>
        <div class="form-actions">
          <div class="status-text" id="tradeStatus" aria-live="polite"></div>
          <button class="submit-btn" id="tradeSubmitBtn" type="submit">Visualizar pedido</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script type="application/json" id="product-json">{{ product|json_encode|raw }}</script>
