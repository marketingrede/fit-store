<main class="container" data-page="home">

  <section class="catalog-intro" aria-label="Sobre a loja">

    <div class="catalog-intro__content">

      <h1 class="catalog-intro__title">
        <span class="catalog-intro__title-text">Loja oficial</span>
        <img src="/assets/logo.svg" alt="Movimenta+" class="catalog-intro__logo" width="461" height="181" decoding="async">
      </h1>

      <p class="catalog-intro__text">

        Troque seu saldo de <strong>Fitcoin</strong> por equipamentos, suplementos e acessórios para turbinar seus treinos.

      </p>

    </div>

  </section>



  <section class="catalog-toolbar" data-catalog-toolbar>

    <div class="catalog-toolbar__row">

      <p class="catalog-count" data-catalog-count>

        {% set catCount = activeCategories|length %}
        {% set tagCount = activeTags|default([])|length %}
        {% set filterCount = catCount + tagCount %}
        {% set total = catalog_total ?? products|length %}

        {% if total == 1 %}

          1 produto{% if filterCount > 0 %} · {{ filterCount }} {{ filterCount == 1 ? 'filtro' : 'filtros' }}{% endif %}

        {% else %}

          {{ total }} produtos{% if filterCount > 0 %} · {{ filterCount }} {{ filterCount == 1 ? 'filtro' : 'filtros' }}{% endif %}

        {% endif %}

      </p>

    </div>



    <div class="catalog-toolbar__mobile" data-filter-summary-mobile {{ activeCategories|length == 0 and activeTags|default([])|length == 0 ? 'hidden' : '' }}>

      <p class="catalog-toolbar__mobile-label {{ activeCategories|length > 0 or activeTags|default([])|length > 0 ? 'is-visible' : '' }}">Filtros ativos</p>

      <div class="active-filters-scroll" data-active-filters-scroll {{ activeCategories|length == 0 and activeTags|default([])|length == 0 ? 'hidden' : '' }}>

        {% for slug in activeCategories %}

          <a

            href="{{ catalog_urls.remove[slug] }}"

            class="filter-chip active filter-chip--removable"

            data-remove-category="{{ slug }}"

            hx-get="{{ catalog_urls.remove[slug] }}"

            hx-target="#spa-outlet"

            hx-push-url="true"

            hx-swap="innerHTML"

          >

            {{ categories[slug] ?? slug }}

            <span aria-hidden="true">&times;</span>

          </a>

        {% endfor %}

        {% for tag in activeTags|default([]) %}

          <a

            href="{{ catalog_urls.remove_tag[tag] }}"

            class="filter-chip active filter-chip--removable"

            data-remove-tag="{{ tag }}"

            hx-get="{{ catalog_urls.remove_tag[tag] }}"

            hx-target="#spa-outlet"

            hx-push-url="true"

            hx-swap="innerHTML"

          >

            {{ tag }}

            <span aria-hidden="true">&times;</span>

          </a>

        {% endfor %}

      </div>

    </div>

  </section>

  <div class="catalog-layout">

    <aside class="catalog-sidebar" aria-label="Filtros do catálogo">
      <div class="catalog-sidebar__section">
        <h2 class="catalog-sidebar__title">Categorias</h2>

        <a
          href="{{ catalog_urls.all }}"
          class="catalog-sidebar__link {{ activeCategories|length == 0 ? 'is-active active' : '' }}"
          data-filter-chip
          data-category="all"
          hx-get="{{ catalog_urls.all }}"
          hx-target="#spa-outlet"
          hx-push-url="true"
          hx-swap="innerHTML"
        >
          <span class="catalog-sidebar__check" aria-hidden="true"></span>
          <span>Todos os produtos</span>
        </a>

        {% for slug, label in categories %}
          <a
            href="{{ catalog_urls.toggle[slug] }}"
            class="catalog-sidebar__link {{ slug in activeCategories ? 'is-active active' : '' }}"
            data-filter-chip
            data-category="{{ slug }}"
            hx-get="{{ catalog_urls.toggle[slug] }}"
            hx-target="#spa-outlet"
            hx-push-url="true"
            hx-swap="innerHTML"
          >
            <span class="catalog-sidebar__check" aria-hidden="true"></span>
            <span>{{ label }}</span>
          </a>
        {% endfor %}
      </div>

      <div class="catalog-sidebar__section">
        <h2 class="catalog-sidebar__title">Tags</h2>

        <a
          href="{{ catalog_urls.clear_tags }}"
          class="catalog-sidebar__link {{ activeTags|default([])|length == 0 ? 'is-active' : '' }}"
          hx-get="{{ catalog_urls.clear_tags }}"
          hx-target="#spa-outlet"
          hx-push-url="true"
          hx-swap="innerHTML"
        >
          <span class="catalog-sidebar__check" aria-hidden="true"></span>
          <span>Todas as tags</span>
        </a>

        {% for tag in tags|default([]) %}
          {% set tagName = tag.name %}
          <a
            href="{{ catalog_urls.toggle_tag[tagName] }}"
            class="catalog-sidebar__link {{ tagName in activeTags|default([]) ? 'is-active active' : '' }}"
            data-filter-tag="{{ tagName }}"
            hx-get="{{ catalog_urls.toggle_tag[tagName] }}"
            hx-target="#spa-outlet"
            hx-push-url="true"
            hx-swap="innerHTML"
          >
            <span class="catalog-sidebar__check" aria-hidden="true"></span>
            <span>{{ tagName }}</span>
          </a>
        {% endfor %}
      </div>

      {% if activeCategories|length > 0 or activeTags|default([])|length > 0 %}
        <a
          href="{{ catalog_urls.clear }}"
          class="catalog-sidebar__clear"
          data-filter-clear
          hx-get="{{ catalog_urls.clear }}"
          hx-target="#spa-outlet"
          hx-push-url="true"
          hx-swap="innerHTML"
        >Limpar filtros</a>
      {% endif %}
    </aside>

    <div class="catalog-results">
      <section
        class="products-grid"
        data-products-grid
        data-catalog-page="{{ catalog_page|default(1) }}"
        data-catalog-has-more="{{ catalog_has_more|default(false) ? 'true' : 'false' }}"
      >

    {% if products|length == 0 %}

      <p class="empty-state">Nenhum produto encontrado com os filtros atuais.</p>

    {% else %}

      {% include 'public/partials/_catalog_grid_items.twig' with { products: products, show_feature_cards: true, catalog_cta_cards: catalog_cta_cards|default([]) } %}

      <div class="catalog-scroll-sentinel" data-catalog-sentinel {{ catalog_has_more|default(false) ? '' : 'hidden' }}></div>

    {% endif %}

      </section>

      <p class="catalog-scroll-status" data-catalog-scroll-status aria-live="polite" hidden></p>
    </div>

  </div>



  <script type="application/json" id="catalog-products">{{ products|json_encode|raw }}</script>

  <script type="application/json" id="active-categories">{{ activeCategories|json_encode|raw }}</script>

  <script type="application/json" id="active-tags">{{ activeTags|default([])|json_encode|raw }}</script>

</main>

