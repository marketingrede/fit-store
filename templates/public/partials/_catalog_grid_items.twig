{% for product in products %}
  {% if show_feature_cards and loop.first and catalog_cta_cards[1] is defined %}
    {% include 'public/partials/_catalog_feature_card.twig' with { card: catalog_cta_cards[1] } %}
  {% endif %}

  {% if show_feature_cards and loop.index == 5 and catalog_cta_cards[2] is defined %}
    {% include 'public/partials/_catalog_feature_card.twig' with { card: catalog_cta_cards[2] } %}
  {% endif %}

  {% include 'public/partials/_product_card.twig' with { product: product } %}
{% endfor %}
