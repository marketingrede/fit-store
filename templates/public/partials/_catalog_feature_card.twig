{% set classes = 'catalog-feature-card catalog-feature-card--desktop catalog-feature-card--' ~ card.variant|default('teal') ~ (card.image_url ? ' catalog-feature-card--has-image' : '') %}

{% if card.link_url %}
<a href="{{ card.link_url }}" class="{{ classes }}" aria-label="{{ card.title|default('Destaque do catálogo') }}">
{% else %}
<article class="{{ classes }}" aria-label="{{ card.title|default('Destaque do catálogo') }}">
{% endif %}
  {% if card.image_url %}
    <img src="{{ card.image_url }}" alt="{{ card.title|default('Destaque do catálogo') }}" class="catalog-feature-card__image" loading="lazy">
  {% endif %}

  {% if card.title or card.body or card.link_label %}
    <div class="catalog-feature-card__content">
      {% if card.title %}
        <h2 class="catalog-feature-card__title">{{ card.title }}</h2>
      {% endif %}
      {% if card.body %}
        <p class="catalog-feature-card__text">{{ card.body }}</p>
      {% endif %}
      {% if card.link_label %}
        <span class="catalog-feature-card__cta">{{ card.link_label }}</span>
      {% endif %}
    </div>
  {% endif %}
{% if card.link_url %}
</a>
{% else %}
</article>
{% endif %}
