{% extends 'layouts/app.twig' %}

{% block title %}Meu Perfil | Colaborador {{ app_name }}{% endblock %}

{% block styles %}
  {% set adminCss = vite_css('admin') %}
  {% if adminCss %}<link rel="stylesheet" href="{{ adminCss }}">{% endif %}
  <style>
    .emp-shell { min-height:100vh; background:var(--grey-50,#f8fafc); }
    .emp-nav { background:#fff; border-bottom:1px solid var(--grey-200,#e2e8f0); padding:.75rem 1.5rem; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; }
    .emp-nav__brand { display:flex; align-items:center; gap:.75rem; }
    .emp-nav__logo { height:32px; width:auto; }
    .emp-nav__title { font-size:.9375rem; font-weight:600; color:var(--grey-900,#0f172a); }
    .emp-nav__links { display:flex; gap:1.5rem; align-items:center; }
    .emp-nav__links a { font-size:.8125rem; color:var(--grey-600,#475569); text-decoration:none; font-weight:500; transition:color .15s; }
    .emp-nav__links a:hover, .emp-nav__links a.active { color:var(--teal,#2dbda8); }
    .emp-nav__user { display:flex; align-items:center; gap:.5rem; }
    .emp-nav__avatar { width:28px; height:28px; border-radius:50%; background:var(--teal,#2dbda8); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:600; }
    .emp-nav__name { font-size:.8125rem; color:var(--grey-700,#334155); }
    .emp-nav__logout { background:none; border:none; color:var(--grey-400,#94a3b8); cursor:pointer; padding:.25rem; transition:color .15s; }
    .emp-nav__logout:hover { color:#ef4444; }
    .emp-main { max-width:960px; margin:0 auto; padding:2rem 1.5rem; }
    .emp-balance { background:linear-gradient(135deg,var(--teal,#2dbda8),#1a9e8f); border-radius:1rem; padding:2rem; color:#fff; margin-bottom:2rem; }
    .emp-balance__label { font-size:.875rem; opacity:.85; margin-bottom:.25rem; }
    .emp-balance__amount { font-size:2.5rem; font-weight:700; line-height:1.1; }
    .emp-balance__unit { font-size:1rem; font-weight:400; opacity:.8; margin-left:.25rem; }
    .emp-balance__name { font-size:.875rem; opacity:.7; margin-top:.75rem; }
    .emp-stats { display:grid; grid-template-columns:repeat(auto-fit,minmax(200px,1fr)); gap:1rem; margin-bottom:2rem; }
    .emp-stat { background:#fff; border-radius:.75rem; padding:1.25rem; border:1px solid var(--grey-200,#e2e8f0); }
    .emp-stat__label { font-size:.75rem; color:var(--grey-500,#64748b); text-transform:uppercase; letter-spacing:.05em; margin-bottom:.25rem; }
    .emp-stat__value { font-size:1.5rem; font-weight:700; color:var(--grey-900,#0f172a); }
    .emp-actions { display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:1rem; }
    .emp-action { display:flex; align-items:center; gap:1rem; background:#fff; border-radius:.75rem; padding:1.25rem; border:1px solid var(--grey-200,#e2e8f0); text-decoration:none; transition:border-color .15s,box-shadow .15s; }
    .emp-action:hover { border-color:var(--teal,#2dbda8); box-shadow:0 2px 8px rgba(45,189,168,.1); }
    .emp-action__icon { width:40px; height:40px; border-radius:.5rem; background:rgba(45,189,168,.1); color:var(--teal,#2dbda8); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .emp-action__text { font-size:.875rem; font-weight:600; color:var(--grey-900,#0f172a); }
    .emp-action__desc { font-size:.75rem; color:var(--grey-500,#64748b); margin-top:.125rem; }
  </style>
{% endblock %}

{% block vite_script %}{% endblock %}

{% block body %}
  <div class="emp-shell">
    <nav class="emp-nav">
      <div class="emp-nav__brand">
        <img src="/assets/logo.svg" alt="Movimenta+" class="emp-nav__logo" height="32">
        <span class="emp-nav__title">Colaborador</span>
      </div>
      <div class="emp-nav__links">
        <a href="/colaborador" class="active">Perfil</a>
        <a href="/colaborador/extrato">Extrato</a>
        <a href="/colaborador/resgates">Resgates</a>
        <a href="/colaborador/catalogo">Catálogo</a>
        <div class="emp-nav__user">
          <div class="emp-nav__avatar">{{ employee.full_name|first|upper }}</div>
          <span class="emp-nav__name">{{ employee.full_name }}</span>
        </div>
        <form method="post" action="/colaborador/logout" style="margin:0">
          <button type="submit" class="emp-nav__logout" title="Sair"><i data-lucide="log-out"></i></button>
        </form>
      </div>
    </nav>

    <main class="emp-main">
      <div class="emp-balance">
        <div class="emp-balance__label">Seu saldo Fitcoin</div>
        <div class="emp-balance__amount">{{ balance }}<span class="emp-balance__unit">FITC</span></div>
        <div class="emp-balance__name">{{ employee.full_name }} — Mat. {{ employee.employee_id }}</div>
      </div>

      <div class="emp-stats">
        <div class="emp-stat">
          <div class="emp-stat__label">Resgates realizados</div>
          <div class="emp-stat__value">{{ total_orders }}</div>
        </div>
        <div class="emp-stat">
          <div class="emp-stat__label">Movimentações</div>
          <div class="emp-stat__value">{{ total_ledger_entries }}</div>
        </div>
      </div>

      <div class="emp-actions">
        <a href="/colaborador/catalogo" class="emp-action">
          <div class="emp-action__icon"><i data-lucide="shopping-bag"></i></div>
          <div>
            <div class="emp-action__text">Resgatar Produtos</div>
            <div class="emp-action__desc">Veja o que você pode resgatar</div>
          </div>
        </a>
        <a href="/colaborador/extrato" class="emp-action">
          <div class="emp-action__icon"><i data-lucide="file-text"></i></div>
          <div>
            <div class="emp-action__text">Ver Extrato</div>
            <div class="emp-action__desc">Histórico de movimentações</div>
          </div>
        </a>
        <a href="/colaborador/resgates" class="emp-action">
          <div class="emp-action__icon"><i data-lucide="package"></i></div>
          <div>
            <div class="emp-action__text">Meus Resgates</div>
            <div class="emp-action__desc">Acompanhe seus pedidos</div>
          </div>
        </a>
      </div>
    </main>
  </div>
{% endblock %}

{% block scripts %}
  <script type="module" src="{{ vite('admin') }}" defer></script>
{% endblock %}