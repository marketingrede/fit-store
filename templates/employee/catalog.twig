{% extends 'layouts/app.twig' %}

{% block title %}Catálogo | Colaborador {{ app_name }}{% endblock %}

{% block styles %}
  {% set adminCss = vite_css('admin') %}
  {% if adminCss %}<link rel="stylesheet" href="{{ adminCss }}">{% endif %}
  <style>
    .emp-shell { min-height:100vh; background:var(--grey-50,#f8fafc); }
    .emp-nav { background:#fff; border-bottom:1px solid var(--grey-200,#e2e8f0); padding:.75rem 1.5rem; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:50; }
    .emp-nav__brand { display:flex; align-items:center; gap:.75rem; }
    .emp-nav__logo { height:32px; width:auto; }
    .emp-nav__title { font-size:.9375rem; font-weight:600; color:var(--grey-900,#0f172a); }
    .emp-nav__links { display:flex; gap:1.5rem; align-items:center; }
    .emp-nav__links a { font-size:.8125rem; color:var(--grey-600,#475569); text-decoration:none; font-weight:500; transition:color .15s; }
    .emp-nav__links a:hover, .emp-nav__links a.active { color:var(--teal,#2dbda8); }
    .emp-nav__user { display:flex; align-items:center; gap:.5rem; }
    .emp-nav__avatar { width:28px; height:28px; border-radius:50%; background:var(--teal,#2dbda8); color:#fff; display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:600; }
    .emp-nav__name { font-size:.8125rem; color:var(--grey-700,#334155); }
    .emp-nav__logout { background:none; border:none; color:var(--grey-400,#94a3b8); cursor:pointer; padding:.25rem; transition:color .15s; }
    .emp-nav__logout:hover { color:#ef4444; }
    .emp-main { max-width:960px; margin:0 auto; padding:2rem 1.5rem; }
    .emp-page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:1rem; }
    .emp-page-header h1 { font-size:1.25rem; font-weight:700; color:var(--grey-900,#0f172a); }
    .emp-balance-inline { background:var(--teal,#2dbda8); color:#fff; padding:.5rem 1rem; border-radius:.5rem; font-size:.875rem; font-weight:600; }
    .emp-catalog-info { font-size:.8125rem; color:var(--grey-500,#64748b); margin-bottom:1.5rem; }
    .emp-catalog-info strong { color:var(--grey-700,#334155); }
    .emp-search { margin-bottom:1.5rem; }
    .emp-search input { width:100%; padding:.75rem 1rem; border:1px solid var(--grey-200,#e2e8f0); border-radius:.5rem; font-size:.875rem; outline:none; transition:border .15s; }
    .emp-search input:focus { border-color:var(--teal,#2dbda8); box-shadow:0 0 0 3px rgba(45,189,168,.15); }
    .emp-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:1rem; }
    .emp-product { background:#fff; border-radius:.75rem; border:1px solid var(--grey-200,#e2e8f0); overflow:hidden; transition:border-color .15s,box-shadow .15s; cursor:pointer; }
    .emp-product:hover { border-color:var(--teal,#2dbda8); box-shadow:0 4px 12px rgba(45,189,168,.1); }
    .emp-product__img { width:100%; aspect-ratio:1; object-fit:cover; background:var(--grey-100,#f1f5f9); }
    .emp-product__body { padding:.75rem; }
    .emp-product__name { font-size:.8125rem; font-weight:600; color:var(--grey-900,#0f172a); margin-bottom:.25rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .emp-product__price { font-size:.875rem; font-weight:700; color:var(--teal,#2dbda8); }
    .emp-product__price span { font-size:.6875rem; font-weight:400; color:var(--grey-500,#64748b); }
    .emp-product__category { font-size:.6875rem; color:var(--grey-400,#94a3b8); margin-top:.25rem; }
    .emp-empty { text-align:center; padding:3rem 1rem; color:var(--grey-500,#64748b); }
    .emp-empty i { width:48px; height:48px; margin-bottom:1rem; opacity:.3; }
    .emp-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:100; align-items:center; justify-content:center; }
    .emp-modal-overlay.active { display:flex; }
    .emp-modal { background:#fff; border-radius:1rem; padding:2rem; max-width:480px; width:90%; max-height:80vh; overflow-y:auto; }
    .emp-modal h2 { font-size:1.125rem; font-weight:700; margin-bottom:.5rem; }
    .emp-modal__img { width:100%; border-radius:.5rem; margin-bottom:1rem; }
    .emp-modal__price { font-size:1.25rem; font-weight:700; color:var(--teal,#2dbda8); margin-bottom:.5rem; }
    .emp-modal__desc { font-size:.8125rem; color:var(--grey-600,#475569); margin-bottom:1rem; line-height:1.5; }
    .emp-modal__actions { display:flex; gap:.75rem; }
    .emp-modal__btn { flex:1; padding:.75rem; border-radius:.5rem; font-size:.875rem; font-weight:600; cursor:pointer; border:none; transition:opacity .15s; }
    .emp-modal__btn--primary { background:var(--teal,#2dbda8); color:#fff; }
    .emp-modal__btn--primary:hover { opacity:.9; }
    .emp-modal__btn--secondary { background:var(--grey-100,#f1f5f9); color:var(--grey-700,#334155); }
    .emp-modal__btn--secondary:hover { background:var(--grey-200,#e2e8f0); }
    .emp-modal__confirm { display:none; text-align:center; padding:1rem 0; }
    .emp-modal__confirm.active { display:block; }
    .emp-modal__success { display:none; text-align:center; padding:1rem 0; }
    .emp-modal__success.active { display:block; }
    .emp-modal__success i { color:#16a34a; margin-bottom:.5rem; }
  </style>
{% endblock %}

{% block vite_script %}{% endblock %}

{% block body %}
  <div class="emp-shell">
    <nav class="emp-nav">
      <div class="emp-nav__brand">
        <img src="/assets/logo.svg" alt="Movimenta+" class="emp-nav__logo" height="32">
        <span class="emp-nav__title">Colaborador</span>
      </div>
      <div class="emp-nav__links">
        <a href="/colaborador">Perfil</a>
        <a href="/colaborador/extrato">Extrato</a>
        <a href="/colaborador/resgates">Resgates</a>
        <a href="/colaborador/catalogo" class="active">Catálogo</a>
        <div class="emp-nav__user">
          <div class="emp-nav__avatar">{{ app.session.employee_name|first|upper ?? 'U' }}</div>
          <span class="emp-nav__name">{{ app.session.employee_name ?? 'Colaborador' }}</span>
        </div>
        <form method="post" action="/colaborador/logout" style="margin:0">
          <button type="submit" class="emp-nav__logout" title="Sair"><i data-lucide="log-out"></i></button>
        </form>
      </div>
    </nav>

    <main class="emp-main">
      <div class="emp-page-header">
        <h1>Catálogo de Produtos</h1>
        <div class="emp-balance-inline">Saldo: {{ balance }} FITC</div>
      </div>

      <div class="emp-catalog-info">
        Mostrando <strong>{{ affordable_count }}</strong> de {{ total_products }} produtos que você pode resgatar.
      </div>

      <div class="emp-search">
        <input type="text" id="catalogSearch" placeholder="Buscar produto..." autocomplete="off">
      </div>

      {% if products|length > 0 %}
        <div class="emp-grid" id="catalogGrid">
          {% for product in products %}
            <div class="emp-product" data-name="{{ product.name|lower }}" data-category="{{ product.category }}" onclick="openProductModal({{ product.id }}, '{{ product.name|e('js') }}', {{ product.price_fitc }}, '{{ product.image_url|e('js') }}', '{{ product.description|e('js') }}')">
              <img class="emp-product__img" src="{{ product.image_url }}" alt="{{ product.name }}" loading="lazy">
              <div class="emp-product__body">
                <div class="emp-product__name">{{ product.name }}</div>
                <div class="emp-product__price">{{ product.price_fitc }} <span>FITC</span></div>
                <div class="emp-product__category">{{ product.category|replace({'-': ' '})|title }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="emp-empty">
          <i data-lucide="shopping-bag"></i>
          <p>Nenhum produto disponível com seu saldo atual.</p>
          <p>Seu saldo: <strong>{{ balance }} FITC</strong></p>
        </div>
      {% endif %}
    </main>
  </div>

  <div class="emp-modal-overlay" id="productModal">
    <div class="emp-modal">
      <div id="modalContent">
        <img class="emp-modal__img" id="modalImg" src="" alt="">
        <h2 id="modalName"></h2>
        <div class="emp-modal__price" id="modalPrice"></div>
        <div class="emp-modal__desc" id="modalDesc"></div>
        <div class="emp-modal__actions">
          <button class="emp-modal__btn emp-modal__btn--primary" onclick="confirmTrade()">Confirmar Resgate</button>
          <button class="emp-modal__btn emp-modal__btn--secondary" onclick="closeProductModal()">Cancelar</button>
        </div>
      </div>
      <div class="emp-modal__confirm" id="modalConfirm">
        <p style="font-weight:600;margin-bottom:1rem">Confirmar resgate deste produto?</p>
        <div class="emp-modal__actions">
          <button class="emp-modal__btn emp-modal__btn--primary" onclick="submitTrade()">Sim, resgatar</button>
          <button class="emp-modal__btn emp-modal__btn--secondary" onclick="showModalContent()">Voltar</button>
        </div>
      </div>
      <div class="emp-modal__success" id="modalSuccess">
        <i data-lucide="check-circle"></i>
        <h2>Resgate realizado!</h2>
        <p style="color:var(--grey-500,#64748b);margin-top:.5rem">Seu novo saldo: <strong id="newBalance"></strong> FITC</p>
        <div style="margin-top:1rem">
          <button class="emp-modal__btn emp-modal__btn--primary" onclick="closeProductModal()">Fechar</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    let currentProduct = null;

    function openProductModal(id, name, price, imageUrl, description) {
      currentProduct = { id, name, price, imageUrl, description };
      document.getElementById('modalImg').src = imageUrl;
      document.getElementById('modalName').textContent = name;
      document.getElementById('modalPrice').textContent = price + ' FITC';
      document.getElementById('modalDesc').textContent = description || '';
      document.getElementById('modalContent').style.display = 'block';
      document.getElementById('modalConfirm').classList.remove('active');
      document.getElementById('modalSuccess').classList.remove('active');
      document.getElementById('productModal').classList.add('active');
    }

    function closeProductModal() {
      document.getElementById('productModal').classList.remove('active');
      currentProduct = null;
    }

    function confirmTrade() {
      document.getElementById('modalContent').style.display = 'none';
      document.getElementById('modalConfirm').classList.add('active');
    }

    function showModalContent() {
      document.getElementById('modalConfirm').classList.remove('active');
      document.getElementById('modalContent').style.display = 'block';
    }

    function submitTrade() {
      const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
      fetch('/api/colaborador/troca', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({
          _csrf: csrf,
          product_id: currentProduct.id,
          product_selection: '{}'
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          document.getElementById('modalConfirm').classList.remove('active');
          document.getElementById('modalSuccess').classList.add('active');
          document.getElementById('newBalance').textContent = data.new_balance;
        } else {
          alert(data.error || 'Erro ao resgatar produto.');
          showModalContent();
        }
      })
      .catch(() => {
        alert('Erro de conexão.');
        showModalContent();
      });
    }

    document.getElementById('catalogSearch')?.addEventListener('input', function(e) {
      const term = e.target.value.toLowerCase();
      document.querySelectorAll('.emp-product').forEach(card => {
        const name = card.dataset.name || '';
        const category = card.dataset.category || '';
        card.style.display = (name.includes(term) || category.includes(term)) ? '' : 'none';
      });
    });

    document.getElementById('productModal')?.addEventListener('click', function(e) {
      if (e.target === this) closeProductModal();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeProductModal();
    });
  </script>
{% endblock %}

{% block scripts %}
  <script type="module" src="{{ vite('admin') }}" defer></script>
{% endblock %}