APP_ENV=local
APP_DEBUG=true
APP_URL=https://fitstore.seudominio.com.br

# Gere com: php -r "echo bin2hex(random_bytes(32));"
SESSION_SECRET=altere-esta-chave-secreta

# Senha usada apenas ao criar novos admins no seed (defina e rode a aplicação)
ADMIN_PASSWORD=altere-esta-senha

# SQLite (caminho relativo à raiz do projeto — usado quando Turso não está configurado)
DB_PATH=data/app.db

# Turso (produção — Render). Deixe vazio para usar SQLite local.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# TURSO_REPLICA_PATH=data/replica.db
# TURSO_SYNC_INTERVAL=60

# Uploads
UPLOAD_MAX_MB=5

# SMTP (opcional — troca de Fitcoin)
SMTP_TO=epilian.silva@redemontagens.com.br
SMTP_FROM=no-reply@seudominio.com.br
