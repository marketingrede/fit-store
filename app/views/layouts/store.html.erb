<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Fit Store — Movimenta+" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen">
    <header class="bg-white border-b border-slate-200">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href="<%= root_path %>" class="text-xl font-bold text-teal-700">Fit Store</a>
        <nav class="flex gap-4 text-sm">
          <a href="<%= colaborador_login_path %>" class="text-slate-600 hover:text-teal-700">Colaborador</a>
          <a href="<%= admin_login_path %>" class="text-slate-600 hover:text-teal-700">Admin</a>
        </nav>
      </div>
    </header>
    <main class="max-w-6xl mx-auto px-4 py-8">
      <%= render "shared/flash" if lookup_context.exists?("shared/flash") %>
      <%= yield %>
    </main>
  </body>
</html>
