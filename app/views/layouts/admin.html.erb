<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Admin — Fit Store" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-100 text-slate-900 min-h-screen">
    <% if current_user %>
      <div class="flex min-h-screen">
        <aside class="w-64 bg-slate-900 text-white shrink-0">
          <div class="p-4 border-b border-slate-700">
            <p class="font-bold text-lg">Fit Store Admin</p>
            <p class="text-xs text-slate-400 truncate"><%= current_user.email %></p>
          </div>
          <nav class="p-4 space-y-1 text-sm">
            <%= link_to "Dashboard", admin_root_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Produtos", admin_products_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Anúncios", admin_announcements_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Trocas (legado)", admin_trade_requests_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Pedidos", admin_trade_orders_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Elegíveis", admin_employee_eligibilities_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Contas", admin_employees_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Saldos FITC", admin_fitc_wallets_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Categorias", admin_catalog_categories_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Tags", admin_catalog_tags_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Variações", admin_variation_presets_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "CTAs", admin_catalog_cta_cards_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
            <%= link_to "Conta", admin_account_path, class: "block px-3 py-2 rounded hover:bg-slate-800" %>
          </nav>
          <div class="p-4 border-t border-slate-700">
            <%= button_to "Sair", admin_logout_path, method: :post, class: "text-sm text-slate-400 hover:text-white" %>
          </div>
        </aside>
        <div class="flex-1">
          <main class="p-8">
            <%= render "shared/flash" %>
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="min-h-screen flex items-center justify-center p-4">
        <%= render "shared/flash" %>
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
