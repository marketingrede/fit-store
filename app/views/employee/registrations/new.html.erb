<% content_for :title, "Cadastro — Colaborador" %>

<div class="max-w-md mx-auto">
  <h1 class="text-2xl font-bold mb-6">Cadastro Colaborador</h1>

  <%= form_with url: colaborador_registro_path, class: "space-y-4" do %>
    <div>
      <label for="employee_id" class="block text-sm font-medium mb-1">Matrícula</label>
      <input type="text" name="employee_id" id="employee_id" required class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <div>
      <label for="email" class="block text-sm font-medium mb-1">E-mail</label>
      <input type="email" name="email" id="email" required class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <div>
      <label for="password" class="block text-sm font-medium mb-1">Senha</label>
      <input type="password" name="password" id="password" required minlength="8" class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <div>
      <label for="password_confirm" class="block text-sm font-medium mb-1">Confirmar senha</label>
      <input type="password" name="password_confirm" id="password_confirm" required minlength="8" class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <button type="submit" class="w-full rounded-lg bg-teal-700 text-white py-2 hover:bg-teal-800">Criar conta</button>
  <% end %>

  <p class="mt-6 text-sm text-center text-slate-600">
    Já tem conta?
    <%= link_to "Faça login", colaborador_login_path, class: "text-teal-700 hover:underline" %>
  </p>
</div>
