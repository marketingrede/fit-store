<% content_for :title, "Catálogo — Resgate" %>

<section>
  <h1 class="text-2xl font-bold mb-2">Catálogo para resgate</h1>
  <p class="text-slate-600 mb-6">
    Saldo: <strong class="text-teal-700"><%= @balance %> FITC</strong> —
    <%= @affordable_count %> de <%= @total_products %> produtos disponíveis
  </p>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <% @products.each do |product| %>
      <article class="bg-white rounded-xl border border-slate-200 p-4 flex gap-4">
        <% if product.image_url.present? %>
          <img src="<%= product.image_url %>" alt="" class="w-20 h-20 object-cover rounded-lg shrink-0">
        <% end %>
        <div>
          <h2 class="font-semibold"><%= product.name %></h2>
          <p class="text-teal-700 font-bold"><%= product.price_fitc %> FITC</p>
        </div>
      </article>
    <% end %>
  </div>

  <% if @products.empty? %>
    <p class="text-slate-500 py-8 text-center">Nenhum produto disponível com seu saldo atual.</p>
  <% end %>
</section>
