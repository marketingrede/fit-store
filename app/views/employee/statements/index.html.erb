<% content_for :title, "Extrato FITC" %>

<section>
  <h1 class="text-2xl font-bold mb-2">Extrato</h1>
  <p class="text-teal-700 font-bold text-xl mb-6">Saldo: <%= @balance %> FITC</p>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b">
        <tr>
          <th class="text-left px-4 py-3">Data</th>
          <th class="text-left px-4 py-3">Tipo</th>
          <th class="text-right px-4 py-3">Valor</th>
          <th class="text-right px-4 py-3">Saldo</th>
          <th class="text-left px-4 py-3">Descrição</th>
        </tr>
      </thead>
      <tbody>
        <% @entries.each do |entry| %>
          <tr class="border-b border-slate-100">
            <td class="px-4 py-3"><%= l(entry.created_at, format: :short) %></td>
            <td class="px-4 py-3"><%= entry.entry_type %></td>
            <td class="px-4 py-3 text-right"><%= entry.amount_fitc %></td>
            <td class="px-4 py-3 text-right"><%= entry.balance_after_fitc %></td>
            <td class="px-4 py-3"><%= entry.description %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
