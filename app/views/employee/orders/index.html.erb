<% content_for :title, "Meus Resgates" %>

<section>
  <h1 class="text-2xl font-bold mb-6">Meus Resgates</h1>

  <% if @orders.any? %>
    <ul class="space-y-3">
      <% @orders.each do |order| %>
        <li class="bg-white rounded-xl border border-slate-200 p-4">
          <div class="flex justify-between items-start">
            <div>
              <h2 class="font-semibold"><%= order.product_name %></h2>
              <p class="text-sm text-slate-500"><%= l(order.created_at, format: :long) %></p>
            </div>
            <div class="text-right">
              <p class="font-bold text-teal-700"><%= order.product_price_fitc %> FITC</p>
              <span class="text-xs uppercase tracking-wide text-slate-500"><%= order.status %></span>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-slate-500">Nenhum resgate realizado ainda.</p>
  <% end %>
</section>
