<% content_for :title, @employee.full_name %>

<%= render "admin/shared/page_header", title: @employee.full_name, description: "#{@employee.employee_id} — #{@employee.email}" do %>
  <button
    type="button"
    class="admin-button admin-button--primary"
    data-open-balance-modal
    data-employee-id="<%= @employee.id %>"
    data-employee-name="<%= @employee.full_name %>"
  >
    <%= lucide_icon "wallet", class: "admin-button__icon" %>
    <span>Ajustar saldo</span>
  </button>
<% end %>

<section class="admin-mini-stat-grid" aria-label="Resumo da conta">
  <div class="admin-mini-stat">
    <span>Saldo FITC</span>
    <strong><%= @wallet.balance_fitc %></strong>
  </div>
  <div class="admin-mini-stat">
    <span>Pedidos</span>
    <strong><%= @orders.size %></strong>
  </div>
  <div class="admin-mini-stat">
    <span>Lançamentos</span>
    <strong><%= @ledger_entries.size %></strong>
  </div>
</section>

<section class="admin-card admin-table-card">
  <div class="admin-card__header">
    <h2>Extrato FITC</h2>
  </div>
  <table>
    <thead>
      <tr>
        <th>Data</th>
        <th>Tipo</th>
        <th class="is-numeric">Valor</th>
        <th>Descrição</th>
      </tr>
    </thead>
    <tbody>
      <% @ledger_entries.each do |entry| %>
        <tr>
          <td><%= l(entry.created_at, format: :short) %></td>
          <td><%= entry.entry_type %></td>
          <td class="is-numeric"><%= entry.amount_fitc %></td>
          <td><%= entry.description %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<section class="admin-card admin-table-card">
  <div class="admin-card__header">
    <h2>Pedidos de resgate</h2>
  </div>
  <table>
    <thead>
      <tr>
        <th>Data</th>
        <th>Produto</th>
        <th class="is-numeric">FITC</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><%= l(order.created_at, format: :short) %></td>
          <td><%= order.product_name %></td>
          <td class="is-numeric"><%= order.product_price_fitc %></td>
          <td><%= admin_trade_status_badge(order.status) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<%= render "admin/fitc_wallets/balance_modal", employees: [@employee] %>
