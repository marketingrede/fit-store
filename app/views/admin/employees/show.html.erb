<% content_for :title, @employee.full_name %>

<h1 class="text-2xl font-bold mb-2"><%= @employee.full_name %></h1>
<p class="text-slate-600 mb-6"><%= @employee.employee_id %> — <%= @employee.email %></p>
<p class="text-xl font-bold text-teal-700 mb-8">Saldo: <%= @wallet.balance_fitc %> FITC</p>

<h2 class="font-semibold mb-4">Extrato</h2>
<div class="bg-white rounded-xl border overflow-hidden mb-8">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b"><tr><th class="px-4 py-3 text-left">Data</th><th class="px-4 py-3">Tipo</th><th class="px-4 py-3 text-right">Valor</th><th class="px-4 py-3">Descrição</th></tr></thead>
    <tbody>
      <% @ledger_entries.each do |e| %>
        <tr class="border-b"><td class="px-4 py-3"><%= l(e.created_at, format: :short) %></td><td class="px-4 py-3"><%= e.entry_type %></td><td class="px-4 py-3 text-right"><%= e.amount_fitc %></td><td class="px-4 py-3"><%= e.description %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<h2 class="font-semibold mb-4">Pedidos</h2>
<div class="bg-white rounded-xl border overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b"><tr><th class="px-4 py-3 text-left">Data</th><th class="px-4 py-3">Produto</th><th class="px-4 py-3 text-right">FITC</th><th class="px-4 py-3">Status</th></tr></thead>
    <tbody>
      <% @orders.each do |o| %>
        <tr class="border-b"><td class="px-4 py-3"><%= l(o.created_at, format: :short) %></td><td class="px-4 py-3"><%= o.product_name %></td><td class="px-4 py-3 text-right"><%= o.product_price_fitc %></td><td class="px-4 py-3"><%= o.status %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
