<% content_for :title, "Contas colaboradores" %>

<%= render "admin/shared/page_header", title: "Contas de colaboradores" %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Matrícula</th>
        <th class="is-numeric">Saldo FITC</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @employees.each do |emp| %>
        <tr>
          <td><%= emp.full_name %></td>
          <td><%= emp.employee_id %></td>
          <td class="is-numeric"><%= emp.fitc_wallet&.balance_fitc || 0 %></td>
          <td class="is-actions">
            <%= link_to "Ver", admin_employee_path(emp), class: "admin-text-link" %>
            <button
              type="button"
              class="admin-text-link"
              data-open-balance-modal
              data-employee-id="<%= emp.id %>"
              data-employee-name="<%= emp.full_name %>"
            >Ajustar saldo</button>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<%= render "admin/fitc_wallets/balance_modal", employees: @employees %>
