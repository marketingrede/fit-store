<% variations_payload = @product.product_attributes.map do |attribute|
     {
       id: attribute.id,
       name: attribute.name,
       unit: attribute.unit,
       required: attribute.required,
       allow_option_image: attribute.allow_option_image,
       options: attribute.product_attribute_options.map do |option|
         {
           id: option.id,
           label: option.label,
           price_fitc_override: option.price_fitc_override,
           image_url: option.image_url
         }
       end
     }
   end %>

<%= form_with model: [:admin, @product],
              class: "admin-form-card admin-form-card--wide",
              data: {
                product_form: true,
                initial_variations: variations_payload.to_json
              } do |f| %>
  <%= admin_form_errors(@product) %>

  <div class="admin-product-form-layout">
    <div class="admin-form-grid">
      <div>
        <%= f.label :name, "Nome" %>
        <%= f.text_field :name, id: "product_name", required: true %>
      </div>
      <div class="admin-form-grid admin-form-grid--2">
        <div>
          <%= f.label :category, "Categoria" %>
          <%= f.select :category, @categories.map { |c| [c.label, c.slug] }, {}, id: "product_category", required: true %>
        </div>
        <div>
          <%= f.label :price_fitc, "Preço FITC" %>
          <%= f.number_field :price_fitc, min: 0, id: "product_price_fitc", required: true %>
        </div>
      </div>
      <div>
        <%= f.label :description, "Descrição" %>
        <%= f.text_area :description, rows: 4, id: "product_description" %>
      </div>
      <div class="admin-form-grid admin-form-grid--2">
        <div>
          <%= f.label :image_url, "URL da imagem" %>
          <%= f.url_field :image_url, id: "product_image_url" %>
        </div>
        <div>
          <%= f.label :tag, "Tag" %>
          <%= f.text_field :tag, id: "product_tag", list: "product-tag-options" %>
          <datalist id="product-tag-options">
            <% @tags.each do |tag| %>
              <option value="<%= tag.name %>"></option>
            <% end %>
          </datalist>
        </div>
      </div>
      <div>
        <%= f.label :active, class: "admin-checkbox-field" do %>
          <%= f.check_box :active, id: "product_active" %>
          <span>Ativo</span>
        <% end %>
      </div>

      <div>
        <div class="admin-variation-block__header">
          <strong>Variações</strong>
          <button type="button" class="admin-text-link" data-add-variation>+ variação</button>
        </div>
        <div class="admin-variations-editor" data-variations-editor></div>
      </div>
    </div>

    <aside class="admin-media-preview" data-product-media-preview>
      <% if @product.image_url.present? %>
        <%= image_tag @product.image_url, alt: "" %>
      <% else %>
        <span class="admin-empty-text">Sem imagem</span>
      <% end %>
    </aside>
  </div>

  <input type="hidden" name="variations_json" value="[]">

  <div class="admin-form-actions">
    <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_products_path, class: "admin-button admin-button--ghost" %>
  </div>
<% end %>
