<% content_for :title, "Produtos" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Produtos</h1>
  <%= link_to "Novo produto", new_admin_product_path, class: "rounded-lg bg-slate-900 text-white px-4 py-2 text-sm hover:bg-slate-800" %>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b">
      <tr>
        <th class="text-left px-4 py-3">Nome</th>
        <th class="text-left px-4 py-3">Categoria</th>
        <th class="text-right px-4 py-3">Preço FITC</th>
        <th class="text-center px-4 py-3">Ativo</th>
        <th class="text-right px-4 py-3">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr class="border-b border-slate-100">
          <td class="px-4 py-3"><%= product.name %></td>
          <td class="px-4 py-3"><%= product.category %></td>
          <td class="px-4 py-3 text-right"><%= product.price_fitc %></td>
          <td class="px-4 py-3 text-center"><%= product.active? ? "Sim" : "Não" %></td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "Editar", edit_admin_product_path(product), class: "text-teal-700 hover:underline" %>
            <%= button_to "Excluir", admin_product_path(product), method: :delete, form: { data: { turbo_confirm: "Excluir produto?" } }, class: "text-red-600 hover:underline inline" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
