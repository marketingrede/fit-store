<% content_for :title, "Trocas legado" %>

<%= render "admin/shared/page_header", title: "Trocas (formulário legado)", description: "Solicitações enviadas pelo fluxo antigo do catálogo." %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Data</th>
        <th>Nome</th>
        <th>E-mail</th>
        <th>Produto</th>
        <th class="is-numeric">FITC</th>
      </tr>
    </thead>
    <tbody>
      <% @trade_requests.each do |request| %>
        <tr>
          <td><%= l(request.created_at, format: :short) %></td>
          <td><%= request.name %></td>
          <td><%= request.email %></td>
          <td><%= request.product_name %></td>
          <td class="is-numeric"><%= request.product_price_fitc %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @trade_requests.empty? %>
    <p class="admin-empty-text">Nenhuma solicitação registrada.</p>
  <% end %>
</section>
