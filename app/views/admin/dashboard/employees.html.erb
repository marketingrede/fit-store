<% content_for :title, "Colaboradores" %>

<div class="admin-page-header">
  <div>
    <h1>Colaboradores</h1>
    <p>Gerencie elegibilidade, contas, saldos FITC e pedidos de resgate.</p>
  </div>
</div>

<section class="admin-stat-grid" aria-label="Indicadores de colaboradores">
  <article class="admin-stat-card">
    <span class="admin-stat-card__icon" aria-hidden="true"></span>
    <span>
      <span class="admin-stat-card__label">Elegíveis</span>
      <strong><%= @stats[:total_eligible] %></strong>
      <span class="admin-stat-card__hint"><%= @stats[:active_eligible] %> ativos</span>
    </span>
  </article>

  <article class="admin-stat-card">
    <span class="admin-stat-card__icon admin-stat-card__icon--blue" aria-hidden="true"></span>
    <span>
      <span class="admin-stat-card__label">Cadastrados</span>
      <strong><%= @stats[:registered] %></strong>
      <span class="admin-stat-card__hint">Contas criadas</span>
    </span>
  </article>

  <article class="admin-stat-card">
    <span class="admin-stat-card__icon" aria-hidden="true"></span>
    <span>
      <span class="admin-stat-card__label">FITC em circulação</span>
      <strong><%= number_with_delimiter(@stats[:total_balance]) %></strong>
      <span class="admin-stat-card__hint">Saldo nas carteiras</span>
    </span>
  </article>

  <article class="admin-stat-card">
    <span class="admin-stat-card__icon admin-stat-card__icon--blue" aria-hidden="true"></span>
    <span>
      <span class="admin-stat-card__label">Pedidos</span>
      <strong><%= @stats[:total_orders] %></strong>
      <span class="admin-stat-card__hint">Resgates registrados</span>
    </span>
  </article>
</section>

<section class="admin-hub-grid" aria-label="Áreas de colaboradores">
  <%= link_to admin_employee_eligibilities_path, class: "admin-hub-card" do %>
    <span>Elegíveis</span>
    <strong><%= @stats[:active_eligible] %></strong>
    <small>Importar e gerenciar whitelist</small>
  <% end %>

  <%= link_to admin_employees_path, class: "admin-hub-card" do %>
    <span>Contas</span>
    <strong><%= @stats[:registered] %></strong>
    <small>Colaboradores cadastrados</small>
  <% end %>

  <%= link_to admin_fitc_wallets_path, class: "admin-hub-card" do %>
    <span>Saldos</span>
    <strong><%= number_with_delimiter(@stats[:total_balance]) %></strong>
    <small>Crédito e débito manual</small>
  <% end %>

  <%= link_to admin_trade_orders_path, class: "admin-hub-card" do %>
    <span>Pedidos</span>
    <strong><%= @stats[:total_orders] %></strong>
    <small>Acompanhar resgates</small>
  <% end %>
</section>
