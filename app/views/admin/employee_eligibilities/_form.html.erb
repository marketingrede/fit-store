<%= form_with model: [:admin, @eligibility], class: "admin-form-card" do |f| %>
  <%= admin_form_errors(@eligibility) %>

  <div class="admin-form-grid">
    <div>
      <%= f.label :employee_id, "Matrícula" %>
      <%= f.text_field :employee_id %>
    </div>
    <div>
      <%= f.label :full_name, "Nome" %>
      <%= f.text_field :full_name %>
    </div>
    <div>
      <%= f.label :email, "E-mail" %>
      <%= f.email_field :email %>
    </div>
    <div>
      <%= f.label :department, "Departamento" %>
      <%= f.text_field :department %>
    </div>
    <div>
      <%= f.label :status, "Status" %>
      <%= f.select :status, %w[active inactive] %>
    </div>
    <div>
      <%= f.label :initial_balance_fitc, "Saldo inicial FITC" %>
      <%= f.number_field :initial_balance_fitc, min: 0 %>
    </div>
    <div>
      <%= f.label :notes, "Observações" %>
      <%= f.text_area :notes, rows: 3 %>
    </div>
  </div>

  <div class="admin-form-actions">
    <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_employee_eligibilities_path, class: "admin-button admin-button--ghost" %>
  </div>
<% end %>
