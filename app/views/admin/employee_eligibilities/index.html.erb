<% content_for :title, "Elegíveis" %>

<%= render "admin/shared/page_header", title: "Colaboradores elegíveis" do %>
  <%= link_to new_admin_employee_eligibility_path, class: "admin-button admin-button--primary" do %>
    <%= lucide_icon "plus", class: "admin-button__icon" %>
    <span>Novo elegível</span>
  <% end %>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Matrícula</th>
        <th>Nome</th>
        <th>Status</th>
        <th class="is-numeric">Saldo inicial</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @eligibilities.each do |eligibility| %>
        <tr>
          <td><%= eligibility.employee_id %></td>
          <td><%= eligibility.full_name %></td>
          <td>
            <span class="admin-status-badge <%= eligibility.status == "active" ? "is-success" : "is-muted" %>">
              <%= eligibility.status.humanize %>
            </span>
          </td>
          <td class="is-numeric"><%= eligibility.initial_balance_fitc %></td>
          <td class="is-actions">
            <%= link_to "Editar", edit_admin_employee_eligibility_path(eligibility), class: "admin-text-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
