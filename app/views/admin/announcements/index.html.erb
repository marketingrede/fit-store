<% content_for :title, "Anúncios" %>

<%= render "admin/shared/page_header", title: "Anúncios" do %>
  <%= link_to new_admin_announcement_path, class: "admin-button admin-button--primary" do %>
    <%= lucide_icon "plus", class: "admin-button__icon" %>
    <span>Novo anúncio</span>
  <% end %>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Título</th>
        <th>Status</th>
        <th>Publicado em</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @announcements.each do |announcement| %>
        <tr>
          <td><%= announcement.title %></td>
          <td><%= admin_announcement_status_badge(announcement.status) %></td>
          <td><%= announcement.published_at ? l(announcement.published_at, format: :short) : "—" %></td>
          <td class="is-actions">
            <%= link_to "Editar", edit_admin_announcement_path(announcement), class: "admin-text-link" %>
            <%= button_to "Excluir", admin_announcement_path(announcement), method: :delete, form: { data: { turbo_confirm: "Excluir anúncio?" } }, class: "admin-danger-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
