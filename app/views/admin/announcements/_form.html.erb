<div data-announcement-editor>
  <%= form_with model: [:admin, @announcement], class: "admin-form-card admin-form-card--wide" do |f| %>
    <%= admin_form_errors(@announcement) %>

    <div class="admin-form-grid admin-form-grid--2">
      <div>
        <%= f.label :title, "Título" %>
        <%= f.text_field :title %>
      </div>
      <div>
        <%= f.label :slug, "Slug" %>
        <%= f.text_field :slug %>
      </div>
      <div>
        <%= f.label :status, "Status" %>
        <%= f.select :status, Announcement.statuses.keys %>
      </div>
      <div>
        <%= f.label :published_at, "Publicado em" %>
        <%= f.datetime_local_field :published_at %>
      </div>
      <div class="admin-form-grid" style="grid-column: 1 / -1">
        <%= f.label :content_html, "Conteúdo" %>
        <div class="admin-quill-editor">
          <div data-quill-mount></div>
        </div>
        <%= f.hidden_field :content_html %>
      </div>
      <div style="grid-column: 1 / -1" data-announcement-image-editor>
        <%= f.label :image_url, "URL da imagem" %>
        <%= f.url_field :image_url, data: { announcement_image: true, announcement_image_input: true } %>
        <div class="admin-media-preview admin-media-preview--crop" data-announcement-crop-stage hidden>
          <img alt="" data-announcement-crop-image />
        </div>
        <div class="admin-form-actions" style="margin-top:10px;padding-top:0;border-top:0">
          <button type="button" class="admin-button admin-button--ghost" data-announcement-crop-apply hidden>
            Aplicar recorte na URL
          </button>
        </div>
        <% if @announcement.image_url.present? %>
          <div class="admin-media-preview" style="margin-top:10px" data-announcement-image-preview>
            <%= image_tag @announcement.image_url, alt: "" %>
          </div>
        <% else %>
          <div class="admin-media-preview" style="margin-top:10px" data-announcement-image-preview hidden></div>
        <% end %>
      </div>
    </div>

    <div class="admin-form-actions">
      <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
      <%= link_to "Cancelar", admin_announcements_path, class: "admin-button admin-button--ghost" %>
    </div>
  <% end %>
</div>
