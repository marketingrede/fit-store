<%= form_with model: [:admin, @tag], class: "admin-form-card", data: { color_picker: true } do |f| %>
  <%= admin_form_errors(@tag) %>

  <div class="admin-form-grid">
    <div>
      <%= f.label :name, "Nome" %>
      <%= f.text_field :name %>
    </div>
    <div>
      <%= f.label :color, "Cor" %>
      <div class="admin-color-picker" data-color-picker>
        <input type="color" value="<%= @tag.color.presence || "#2dbda8" %>" aria-label="Seletor de cor">
        <%= f.text_field :color, placeholder: "#2dbda8" %>
      </div>
    </div>
    <div>
      <%= f.label :sort_order, "Ordem" %>
      <%= f.number_field :sort_order, min: 0 %>
    </div>
    <div>
      <%= f.label :active, class: "admin-checkbox-field" do %>
        <%= f.check_box :active %>
        <span>Ativa</span>
      <% end %>
    </div>
  </div>

  <div class="admin-form-actions">
    <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_catalog_tags_path, class: "admin-button admin-button--ghost" %>
  </div>
<% end %>
