<% content_for :title, "Tags" %>

<%= render "admin/shared/page_header", title: "Tags do catálogo" do %>
  <%= link_to new_admin_catalog_tag_path, class: "admin-button admin-button--primary" do %>
    <%= lucide_icon "plus", class: "admin-button__icon" %>
    <span>Nova tag</span>
  <% end %>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Cor</th>
        <th class="is-numeric">Ordem</th>
        <th>Status</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @tags.each do |tag| %>
        <tr>
          <td><%= tag.name %></td>
          <td><%= admin_tag_swatch(tag.color, label: tag.color.presence || "Sem cor") %></td>
          <td class="is-numeric"><%= tag.sort_order %></td>
          <td>
            <span class="admin-status-badge <%= tag.active? ? "is-success" : "is-muted" %>">
              <%= tag.active? ? "Ativa" : "Inativa" %>
            </span>
          </td>
          <td class="is-actions">
            <%= link_to "Editar", edit_admin_catalog_tag_path(tag), class: "admin-text-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
