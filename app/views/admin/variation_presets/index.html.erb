<% content_for :title, "Presets de variação" %>

<%= render "admin/shared/page_header", title: "Presets de variação" do %>
  <%= link_to new_admin_variation_preset_path, class: "admin-button admin-button--primary" do %>
    <%= lucide_icon "plus", class: "admin-button__icon" %>
    <span>Novo preset</span>
  <% end %>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Nome</th>
        <th>Unidade</th>
        <th>Obrigatório</th>
        <th>Status</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @presets.each do |preset| %>
        <tr>
          <td><%= preset.name %></td>
          <td><%= preset.unit.presence || "—" %></td>
          <td><%= preset.required? ? "Sim" : "Não" %></td>
          <td>
            <span class="admin-status-badge <%= preset.active? ? "is-success" : "is-muted" %>">
              <%= preset.active? ? "Ativo" : "Inativo" %>
            </span>
          </td>
          <td class="is-actions">
            <%= link_to "Editar", edit_admin_variation_preset_path(preset), class: "admin-text-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
