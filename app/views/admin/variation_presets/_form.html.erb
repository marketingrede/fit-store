<%= form_with model: [:admin, @preset], class: "admin-form-card" do |f| %>
  <%= admin_form_errors(@preset) %>

  <div class="admin-form-grid">
    <div>
      <%= f.label :name, "Nome" %>
      <%= f.text_field :name %>
    </div>
    <div>
      <%= f.label :unit, "Unidade" %>
      <%= f.text_field :unit %>
    </div>
    <div>
      <%= f.label :options_json, "Opções (JSON)" %>
      <%= f.text_area :options_json, rows: 5 %>
    </div>
    <div>
      <%= f.label :sort_order, "Ordem" %>
      <%= f.number_field :sort_order, min: 0 %>
    </div>
    <div>
      <%= f.label :required, class: "admin-checkbox-field" do %>
        <%= f.check_box :required %>
        <span>Obrigatório</span>
      <% end %>
    </div>
    <div>
      <%= f.label :active, class: "admin-checkbox-field" do %>
        <%= f.check_box :active %>
        <span>Ativo</span>
      <% end %>
    </div>
  </div>

  <div class="admin-form-actions">
    <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_variation_presets_path, class: "admin-button admin-button--ghost" %>
  </div>
<% end %>
