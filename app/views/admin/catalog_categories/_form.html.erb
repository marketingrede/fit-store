<%= form_with model: [:admin, @category], class: "admin-form-card" do |f| %>
  <%= admin_form_errors(@category) %>

  <div class="admin-form-grid">
    <div>
      <%= f.label :slug, "Slug" %>
      <%= f.text_field :slug %>
    </div>
    <div>
      <%= f.label :label, "Label" %>
      <%= f.text_field :label %>
    </div>
    <div>
      <%= f.label :sort_order, "Ordem" %>
      <%= f.number_field :sort_order, min: 0 %>
    </div>
    <div>
      <%= f.label :active, class: "admin-checkbox-field" do %>
        <%= f.check_box :active %>
        <span>Ativa</span>
      <% end %>
    </div>
  </div>

  <div class="admin-form-actions">
    <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
    <%= link_to "Cancelar", admin_catalog_categories_path, class: "admin-button admin-button--ghost" %>
  </div>
<% end %>
