<% content_for :title, "Categorias" %>

<%= render "admin/shared/page_header", title: "Categorias do catálogo" do %>
  <%= link_to new_admin_catalog_category_path, class: "admin-button admin-button--primary" do %>
    <%= lucide_icon "plus", class: "admin-button__icon" %>
    <span>Nova categoria</span>
  <% end %>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Slug</th>
        <th>Label</th>
        <th class="is-numeric">Ordem</th>
        <th>Status</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |category| %>
        <tr>
          <td><code><%= category.slug %></code></td>
          <td><%= category.label %></td>
          <td class="is-numeric"><%= category.sort_order %></td>
          <td>
            <span class="admin-status-badge <%= category.active? ? "is-success" : "is-muted" %>">
              <%= category.active? ? "Ativa" : "Inativa" %>
            </span>
          </td>
          <td class="is-actions">
            <%= link_to "Editar", edit_admin_catalog_category_path(category), class: "admin-text-link" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
