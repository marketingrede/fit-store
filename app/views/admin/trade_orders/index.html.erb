<% content_for :title, "Pedidos de resgate" %>

<%= render "admin/shared/page_header", title: "Pedidos de resgate" %>

<section class="admin-filter-card" aria-label="Filtro de status">
  <%= form_with url: admin_trade_orders_path, method: :get, class: "admin-filter-form" do %>
    <div>
      <label for="status">Status</label>
      <select id="status" name="status">
        <%= options_for_select([["Todos", ""]] + TradeOrder.distinct.pluck(:status).compact.sort.map { |s| [s.humanize, s] }, @status_filter) %>
      </select>
    </div>
    <button type="submit" class="admin-button admin-button--primary">Filtrar</button>
  <% end %>
</section>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>Data</th>
        <th>Colaborador</th>
        <th>Produto</th>
        <th class="is-numeric">FITC</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><%= order.id %></td>
          <td><%= l(order.created_at, format: :short) %></td>
          <td><%= order.employee.full_name %></td>
          <td><%= order.product_name %></td>
          <td class="is-numeric"><%= order.product_price_fitc %></td>
          <td>
            <%= form_with url: admin_trade_order_path(order), method: :patch, local: true, class: "admin-inline-form" do |f| %>
              <%= f.select :status,
                TradeOrder.statuses.keys.map { |s| [s.humanize, s] },
                { selected: order.status },
                { onchange: "this.form.submit()" } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if @orders.empty? %>
    <p class="admin-empty-text">Nenhum pedido encontrado.</p>
  <% end %>
</section>
