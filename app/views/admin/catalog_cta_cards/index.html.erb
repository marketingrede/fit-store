<% content_for :title, "CTAs do catálogo" %>

<h1 class="text-2xl font-bold mb-6">Cards CTA</h1>
<div class="grid md:grid-cols-2 gap-4">
  <% @cards.each do |card| %>
    <article class="bg-white rounded-xl border p-6">
      <p class="text-xs text-slate-500 mb-2">Slot <%= card.slot %></p>
      <h2 class="font-semibold"><%= card.title %></h2>
      <p class="text-sm text-slate-600 mt-2"><%= card.body %></p>
      <p class="mt-4"><%= link_to "Editar", edit_admin_catalog_cta_card_path(card), class: "text-teal-700" %></p>
    </article>
  <% end %>
</div>
