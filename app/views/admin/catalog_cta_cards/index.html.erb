<% content_for :title, "Cards CTA" %>

<%= render "admin/shared/page_header", title: "Cards CTA", description: "Banners promocionais exibidos no catálogo." %>

<section class="admin-hub-grid admin-hub-grid--reports">
  <% @cards.each do |card| %>
    <%= link_to edit_admin_catalog_cta_card_path(card), class: "admin-hub-card" do %>
      <span>Slot <%= card.slot %> — <%= card.variant %></span>
      <strong><%= card.title %></strong>
      <small><%= truncate(card.body.to_s, length: 80) %></small>
    <% end %>
  <% end %>
</section>
