<% content_for :title, "Editar CTA" %>

<%= render "admin/shared/page_header", title: "Editar CTA", description: "Slot #{@card.slot}" %>

<div data-cta-editor>
  <%= form_with model: [:admin, @card], class: "admin-cta-editor" do |f| %>
    <section class="admin-form-card">
      <%= admin_form_errors(@card) %>

      <div class="admin-form-grid">
        <div>
          <%= f.label :title, "Título" %>
          <%= f.text_field :title, id: "catalog_cta_card_title" %>
        </div>
        <div>
          <%= f.label :body, "Texto" %>
          <%= f.text_area :body, rows: 3, id: "catalog_cta_card_body" %>
        </div>
        <div>
          <%= f.label :link_url, "URL" %>
          <%= f.url_field :link_url %>
        </div>
        <div>
          <%= f.label :link_label, "Label do link" %>
          <%= f.text_field :link_label, id: "catalog_cta_card_link_label" %>
        </div>
        <div>
          <%= f.label :variant, "Variante" %>
          <%= f.select :variant, %w[teal blue], {}, id: "catalog_cta_card_variant" %>
        </div>
        <div>
          <%= f.label :image_url, "URL da imagem" %>
          <%= f.url_field :image_url %>
        </div>
        <div>
          <%= f.label :active, class: "admin-checkbox-field" do %>
            <%= f.check_box :active %>
            <span>Ativo</span>
          <% end %>
        </div>
      </div>

      <div class="admin-form-actions">
        <%= f.submit "Salvar", class: "admin-button admin-button--primary" %>
        <%= link_to "Voltar", admin_catalog_cta_cards_path, class: "admin-button admin-button--ghost" %>
      </div>
    </section>

    <aside class="admin-cta-preview" aria-label="Prévia do card">
      <p class="admin-card__text">Prévia ao vivo</p>
      <div data-cta-preview-card class="admin-cta-preview-card admin-cta-preview-card--<%= @card.variant %>">
        <h3><%= @card.title %></h3>
        <p><%= @card.body %></p>
        <a href="#"><%= @card.link_label %></a>
      </div>
    </aside>
  <% end %>
</div>
