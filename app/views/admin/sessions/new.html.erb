<% content_for :title, "Login - Admin" %>

<section class="admin-login-card" aria-labelledby="admin-login-title">
  <%= image_tag "/logo.svg", alt: "Movimenta+", class: "admin-login-card__logo" %>
  <p class="admin-login-card__eyebrow">Painel administrativo</p>
  <h1 id="admin-login-title">Fit Store</h1>
  <p class="admin-login-card__text">Entre para gerenciar produtos, anúncios e trocas.</p>

  <%= form_with url: admin_login_path, class: "admin-login-form" do %>
    <div>
      <label for="email">E-mail</label>
      <input type="email" name="email" id="email" required autocomplete="username" placeholder="seu@email.com">
    </div>
    <div>
      <label for="password">Senha</label>
      <input type="password" name="password" id="password" required autocomplete="current-password" placeholder="••••••••">
    </div>
    <button type="submit" class="admin-button admin-button--primary admin-button--full">Entrar</button>
  <% end %>

  <%= link_to "Voltar para a loja", root_path, class: "admin-login-card__back" %>
</section>
