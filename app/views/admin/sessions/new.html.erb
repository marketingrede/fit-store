<% content_for :title, "Login — Admin" %>

<div class="w-full max-w-md bg-white rounded-xl border border-slate-200 p-8 shadow-sm">
  <h1 class="text-2xl font-bold mb-6">Admin Fit Store</h1>

  <%= form_with url: admin_login_path, class: "space-y-4" do %>
    <div>
      <label for="email" class="block text-sm font-medium mb-1">E-mail</label>
      <input type="email" name="email" id="email" required autocomplete="username" class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <div>
      <label for="password" class="block text-sm font-medium mb-1">Senha</label>
      <input type="password" name="password" id="password" required autocomplete="current-password" class="w-full rounded-lg border border-slate-300 px-3 py-2">
    </div>
    <button type="submit" class="w-full rounded-lg bg-slate-900 text-white py-2 hover:bg-slate-800">Entrar</button>
  <% end %>
</div>
