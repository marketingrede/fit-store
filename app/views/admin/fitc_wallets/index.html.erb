<% content_for :title, "Saldos FITC" %>

<%= render "admin/shared/page_header", title: "Saldos FITC", description: "Consulte saldos e ajuste créditos ou débitos manualmente." do %>
  <button type="button" class="admin-button admin-button--primary" data-open-balance-modal>
    <%= lucide_icon "banknote", class: "admin-button__icon" %>
    <span>Ajustar saldo</span>
  </button>
<% end %>

<section class="admin-table-card">
  <table>
    <thead>
      <tr>
        <th>Colaborador</th>
        <th>Matrícula</th>
        <th class="is-numeric">Saldo FITC</th>
        <th class="is-actions">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @wallets.each do |wallet| %>
        <tr>
          <td><%= wallet.employee.full_name %></td>
          <td><%= wallet.employee.employee_id %></td>
          <td class="is-numeric"><strong><%= wallet.balance_fitc %></strong></td>
          <td class="is-actions">
            <button
              type="button"
              class="admin-text-link"
              data-open-balance-modal
              data-employee-id="<%= wallet.employee.id %>"
              data-employee-name="<%= wallet.employee.full_name %>"
            >Ajustar</button>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>

<%= render "balance_modal", employees: @employees %>
