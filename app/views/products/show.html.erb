<% content_for :title, @product.name %>

<article class="max-w-3xl mx-auto">
  <a href="<%= root_path %>" class="text-sm text-teal-700 hover:underline mb-4 inline-block">&larr; Voltar ao catálogo</a>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @product.image_url.present? %>
      <img src="<%= @product.image_url %>" alt="" class="w-full max-h-96 object-cover">
    <% end %>
    <div class="p-6">
      <% if @product.tag.present? %>
        <span class="text-sm font-medium text-teal-700"><%= @product.tag %></span>
      <% end %>
      <h1 class="text-3xl font-bold mt-1"><%= @product.name %></h1>
      <p class="text-2xl font-bold text-teal-700 mt-4"><%= @product.price_fitc %> FITC</p>
      <% if @product.description.present? %>
        <p class="mt-4 text-slate-600 leading-relaxed"><%= @product.description %></p>
      <% end %>
    </div>
  </div>
</article>
